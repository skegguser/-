                        local zombies = workspace:FindFirstChild("Zombies")
                        if zombies then
                            for _, z in ipairs(zombies:GetChildren()) do
                                if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                                    local zRoot = z.HumanoidRootPart
                                    if (zRoot.Position - hrp.Position).Magnitude <= KillAuraRange then
                                        local tool = char:FindFirstChildOfClass("Tool")
                                        if tool and tool:FindFirstChild("RemoteEvent") then
                                            local remote = tool.RemoteEvent
                                            remote:FireServer("Swing", "Thrust")
                                            task.wait(0.05)
                                            remote:FireServer("HitZombie", z, zRoot.Position, true)
                                        end
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
    end,
})
KillAuraTab:Slider({
    Title = "Kill Aura Range",
    Desc = "Max distance",
    Value = { Min = 5, Max = 30, Default = 19 },
    Callback = function(v) KillAuraRange = v end,
})

