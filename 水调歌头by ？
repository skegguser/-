-- 杀戮光环与肘击逻辑 (File 1, 3 结合)
RunService.Heartbeat:Connect(function()
    if not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if CFG.KILL_AURA_ON then
        local zombies = workspace:FindFirstChild("Zombies")
        if zombies then
            local weapon = LocalPlayer.Character:FindFirstChildOfClass("Tool")
            if weapon and weapon:FindFirstChild("RemoteEvent") then
                for _, z in pairs(zombies:GetChildren()) do
                    if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                        local dist = (hrp.Position - z.HumanoidRootPart.Position).Magnitude
                        -- 杀戮触发
                        weapon.RemoteEvent:FireServer("HitZombie", z, z.HumanoidRootPart.Position, true)
                        -- 肘击逻辑：在13-35范围内同时作用
                        if dist >= 13 and dist <= 35 then
                            weapon.RemoteEvent:FireServer("Shove")
                            weapon.RemoteEvent:FireServer("FeedbackStun", z, z.HumanoidRootPart.Position)
                        end
                    end
                end
            end
        end
    end

    -- 职业功能：医生自动包扎
    if CFG.MEDIC_AUTO then
        local med = LocalPlayer.Character:FindFirstChild("Medical Supplies")
        if med and med:FindFirstChild("RemoteEvent") then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
                    if p.Character.Humanoid.Health < 30 then
                        med.RemoteEvent:FireServer("SendRequest", p.Character.Humanoid)
                    end
                end
            end
        end
    end
end)

