local function findPlayerByText(text)
    text = text:lower()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Name:lower():find(text) or plr.DisplayName:lower():find(text) then
            return plr
        end
    end
end

LocalPlayer.Chatted:Connect(function(msg)
    if not CFG.SEMI_GOD_ON then return end
    if msg:sub(1,6):lower() == ";kill " then
        local name = msg:sub(7)
        local plr = findPlayerByText(name)
        if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            semiGodTarget = plr
        end
    end
end)

----------------------------------------------------------------------
-- 核心功能循环 (合并战斗、职业、地图自动化)
----------------------------------------------------------------------
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    -- 【玩家功能】半无敌执行
    if CFG.SEMI_GOD_ON and semiGodTarget and semiGodTarget.Character then
        local tChar = semiGodTarget.Character
        local tHrp = tChar:FindFirstChild("HumanoidRootPart")
        if tHrp and tChar.Humanoid.Health > 0 then
            local offset = tHrp.Velocity.Magnitude < 0.1 and 0 or 7
            local goal = tHrp.CFrame * CFrame.new(0,0,-offset) * CFrame.Angles(0, math.rad(-3), 0)
            hrp.CFrame = hrp.CFrame:Lerp(goal, 0.4)
            hrp.Velocity = Vector3.new(0,0,0)
            hrp.RotVelocity = Vector3.new(0,0,0)
        else
            semiGodTarget = nil
        end
    end

    -- 【玩家功能】保持移动 (防挂机/布娃娃)
    if CFG.SEMI_GOD_ON then
        hum:Move(Vector3.one * 1e31)
    end

    -- 【玩家功能】无减速
    if CFG.NO_SLOW and hum.WalkSpeed < 16 then
        hum.WalkSpeed = 16
    end

    -- 【战斗功能】杀戮光环 (全距离触发)
    if CFG.KILL_AURA_ON then
        local zombies = workspace:FindFirstChild("Zombies")
        if zombies then
            local weapon = char:FindFirstChild("Musket") or char:FindFirstChildWhichIsA("Tool")
            if weapon and weapon:FindFirstChild("RemoteEvent") then
                for _, z in pairs(zombies:GetChildren()) do
                    if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                        local zHrp = z.HumanoidRootPart
                        -- 距离设置为巨大，近距远距皆触发
                        if (hrp.Position - zHrp.Position).Magnitude <= CFG.SCAN_DIST then
                            local state = z:FindFirstChild("State")
                            if not state or state.Value ~= "Spawn" then
                                weapon.RemoteEvent:FireServer("Swing", "Thrust")
                                weapon.RemoteEvent:FireServer("HitZombie", z, zHrp.Position, true)
                            end
                        end
                    end
                end
            end
        end
    end

    -- 【战斗功能】卡宾枪/肘击
    if CFG.ELBOW_STRIKE_ON or CFG.CARBINE_STUN_ON then
        local weaponName = CFG.ELBOW_STRIKE_ON and "Axe" or "Carbine"
        local weapon = char:FindFirstChild(weaponName)
        if weapon and weapon:FindFirstChild("RemoteEvent") then
            local zombies = workspace:FindFirstChild("Zombies")
            if zombies then
                for _, z in pairs(zombies:GetChildren()) do
                    if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                        if (hrp.Position - z.HumanoidRootPart.Position).Magnitude <= 15 then
                            if CFG.ELBOW_STRIKE_ON then
                                weapon.RemoteEvent:FireServer("BraceBlock")
                                weapon.RemoteEvent:FireServer("StopBraceBlock")
                            else
                                weapon.RemoteEvent:FireServer("Shove")
                            end
                            weapon.RemoteEvent:FireServer("FeedbackStun", z, z.HumanoidRootPart.Position)
                        end
                    end
                end
            end
        end
    end

    -- 【辅助类】地图自动化
    if CFG.AUTO_BRIDGE then
        local bridge = workspace:FindFirstChild("Berezina")
        if bridge then
            local hammer = LocalPlayer.Backpack:FindFirstChild("Hammer") or char:FindFirstChild("Hammer")
            if hammer and hammer:FindFirstChild("RemoteEvent") then
                for _, part in ipairs(bridge:GetDescendants()) do
                    if part:FindFirstChild("ConstructHealth") and (part.Position - hrp.Position).Magnitude < 20 then
                        hammer.RemoteEvent:FireServer("Repair", part.ConstructHealth)
                    end
                end
            end
        end
    end

    if CFG.AUTO_PLACE_LOGS then
        for _, prompt in pairs(workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Name == "PlaceLogProximityPrompt" then
                fireproximityprompt(prompt)
            end
        end
    end

    -- 【职业】医疗兵自动治疗
    if CFG.MEDIC_HEAL then
        local med = char:FindFirstChild("Medical Supplies")
        if med and med:FindFirstChild("RemoteEvent") then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local pHum = p.Character:FindFirstChildOfClass("Humanoid")
                    if pHum and pHum.Health <= pHum.MaxHealth * 0.25 then
                        med.RemoteEvent:FireServer("SendRequest", pHum)
                    end
                end
            end
        end
    end

    -- 【职业】牧师自动祝福
    if CFG.CHAPLAIN_BLESS then
        local bless = char:FindFirstChild("Blessing")
        if bless and bless:FindFirstChild("RemoteEvent") then
            local wsPlayers = workspace:FindFirstChild("Players")
            if wsPlayers then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer then
                        local pFolder = wsPlayers:FindFirstChild(p.Name)
                        if pFolder and pFolder:FindFirstChild("UserStates") then
                            local inf = pFolder.UserStates:FindFirstChild("Infected")
                            if inf and tonumber(inf.Value) >= 50 then
                                local pHum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")
                                if pHum then bless.RemoteEvent:FireServer("SendRequest", pHum) end
                            end
                        end
                    end
                end
            end
        end
    end
end)

