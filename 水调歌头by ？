-- ================== 玩家功能 Section（半无敌） ==================
local PlayerTab = Sections.Player:Tab({ Title = "半无敌", Icon = "shield" })

PlayerTab:Toggle({
    Title = "半无敌模式",
    Desc = "输入 ;kill 玩家名 后自动跟随并碰撞目标",
    Default = false,
    Callback = function(state)
        _G.SemiGod = state
        if state then
            local Players = game:GetService("Players")
            local lp = Players.LocalPlayer
            local targetPlayer = nil

            local function findPlayer(text)
                text = text:lower()
                for _, plr in pairs(Players:GetPlayers()) do
                    if plr.Name:lower():find(text) or plr.DisplayName:lower():find(text) then
                        return plr
                    end
                end
            end

            lp.Chatted:Connect(function(msg)
                if not _G.SemiGod then return end
                if msg:sub(1,6):lower() == ";kill " then
                    local name = msg:sub(7)
                    local plr = findPlayer(name)
                    if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                        targetPlayer = plr
                    end
                end
            end)

            task.spawn(function()
                while _G.SemiGod do
                    if targetPlayer then
                        local char = targetPlayer.Character
                        if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                            local myChar = lp.Character
                            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
                            local targetHRP = char:FindFirstChild("HumanoidRootPart")
                            if myHRP and targetHRP then
                                myHRP.CFrame = targetHRP.CFrame * CFrame.new(0,0,-7) * CFrame.Angles(0, math.rad(-3), 0)
                            end
                        else
                            targetPlayer = nil
                        end
                    end
                    task.wait()
                end
            end)

            task.spawn(function()
                while _G.SemiGod do
                    local hum = lp.Character and lp.Character:FindFirstChild("Humanoid")
                    if hum then hum:Move(Vector3.one * 1e31) end
                    task.wait()
                end
            end)
        end
    end,
})

