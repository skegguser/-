local function performReload(tool, targetShots)
    if reloadInProgress[tool] then return end
    reloadInProgress[tool] = true
    local remote = findRemote(tool)
    if not remote then reloadInProgress[tool]=nil return end
    if targetShots>1 then pcall(function() remote:FireServer("StartReload") end) task.wait(0.1) end
    for _=1,50 do
        if getShotsLoaded(tool) >= targetShots then
            pcall(function() tool.Parent = LocalPlayer.Backpack end)
            task.wait(0.02)
            pcall(function() tool.Parent = LocalPlayer.Character end)
            break
        end
        pcall(function() remote:FireServer("Reload") end)
        task.wait(0.05)
    end
    reloadInProgress[tool]=nil
end

local function tryReload(tool)
    if not GUN_AUTO_RELOAD or not isGun(tool) then return end
    local shots = getShotsLoaded(tool)
    if tool.Name=="Nock Gun" and shots<7 then task.spawn(performReload,tool,7)
    elseif (tool.Name=="Double Barrel Pistol" or tool.Name=="Horse Artillery Pistol") and shots==0 then task.spawn(performReload,tool,2)
    elseif shots==0 then task.spawn(performReload,tool,1) end
end

local function getNearestZombieGun(range)
    local cam = Workspace.CurrentCamera
    local origin = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position or cam.CFrame.Position
    if not origin then return nil end
    local bestPart,bestDist = nil,range
    local zombies = Workspace:FindFirstChild("Zombies")
    if not zombies then return nil end
    for _,model in ipairs(zombies:GetDescendants()) do
        if model:IsA("Model") and not model:FindFirstChild("Spawn") then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then
                local aimPart = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
                if aimPart then
                    local aimPos = getPredictedPos(aimPart)
                    if isWorldPosInFov(aimPos) then
                        local d = (aimPos-origin).Magnitude
                        if d<=bestDist then
                            bestPart = aimPart
                            bestDist = d
                        end
                    end
                end
            end
        end
    end
    return bestPart
end

