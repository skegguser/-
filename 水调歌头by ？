local function createESP(model, color, label)
    if espHighlights[model] then return end
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
    if not torso then return end
    local hl = Instance.new("Highlight", model)
    hl.FillColor, hl.OutlineColor = color, Color3.new(1,1,1)
    hl.FillTransparency = 0.4
    hl.DepthMode = "AlwaysOnTop"
    local bgui = Instance.new("BillboardGui", torso)
    bgui.Size, bgui.AlwaysOnTop, bgui.StudsOffset = UDim2.new(0,80,0,30), true, Vector3.new(0,3,0)
    local tl = Instance.new("TextLabel", bgui)
    tl.BackgroundTransparency, tl.Size, tl.Text = 1, UDim2.new(1,0,1,0), label
    tl.TextColor3, tl.TextStrokeTransparency, tl.TextSize, tl.Font = color, 0, 14, "SourceSansBold"
    espHighlights[model] = {hl = hl, gui = bgui}
end

