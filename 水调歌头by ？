-- ================= 无敌碰飞（完全按照碰飞.lua） =================
local wudiTargetPlayer = nil
local wudiMoveLoopRunning = true
local wudiPushLoopRunning = true

local function findPlayer(text)
    text = text:lower()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Name:lower():find(text) or plr.DisplayName:lower():find(text) then
            return plr
        end
    end
end

LocalPlayer.Chatted:Connect(function(msg)
    if not CFG.WUDI_ON then return end
    if msg:sub(1,6):lower() == ";kill " then
        local name = msg:sub(7)
        local plr = findPlayer(name)
        if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            wudiTargetPlayer = plr
        end
    end
end)

task.spawn(function()
    while wudiMoveLoopRunning do
        task.wait(0)
        if not CFG.WUDI_ON or not wudiTargetPlayer then
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum:Move(Vector3.zero) end
            continue
        end
        local char = wudiTargetPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
            wudiTargetPlayer = nil
            continue
        end
        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local targetHRP = char:FindFirstChild("HumanoidRootPart")
        if myHRP and targetHRP then
            local offset = targetHRP.Velocity.Magnitude < 0.1 and 0 or 7
            local goal = targetHRP.CFrame * CFrame.new(0,0,-offset) * CFrame.Angles(0, math.rad(-3), 0)
            myHRP.CFrame = myHRP.CFrame:Lerp(goal, 0.4)
            myHRP.Velocity = Vector3.new(0,0,0)
            myHRP.RotVelocity = Vector3.new(0,0,0)
        end
    end
end)

