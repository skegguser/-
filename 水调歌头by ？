        createFeatureButton(subScroll, "飞行绕过", false, function(s) if s then createFlyUI() end end)
        local speedBtn = createFeatureButton(subScroll, "移速", false, function() end, true)
        speedBtn.Text = "移速: " .. CFG.LOOP_SPEED
        speedBtn.MouseButton1Click:Connect(function()
            local newS = CFG.LOOP_SPEED + 1
            if newS > 45 then newS = 16 end
            CFG.LOOP_SPEED = newS
            speedBtn.Text = "移速: " .. CFG.LOOP_SPEED
            updateWalkSpeed()
        end)
    end
    if name == "玩家" then
        createFeatureButton(subScroll, "半无敌", false, function(s) CFG.HALF_WUDI = s end)
    end
    if name == "视觉效果" then
        createFeatureButton(subScroll, "僵尸透视", false, function(s) CFG.ESP = s end)
        createFeatureButton(subScroll, "全图高亮", false, function(s) CFG.FULLBRIGHT = s; updateFullbright() end)
    end
    if name == "界面设置" then
        createFeatureButton(subScroll, "显示状态", true, function() ShowStatus = not ShowStatus updateStatusPanel() end)
        createFeatureButton(subScroll, "自由拖拽", true, function() LockSubUIs = not LockSubUIs end)
        createFeatureButton(subScroll, "彩虹标题", true, function() UseRainbowTitle = not UseRainbowTitle updateAllThemes() end)
