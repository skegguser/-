        createFeatureButton(subScroll, "调整界面大小", true, function() local s = CategoryStates["调整界面大小"] ResizeHandle.Visible = s TweenService:Create(resizeContainer, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = s and UDim2.new(1, 0, 0, BAR_HEIGHT) or UDim2.new(1, 0, 0, 0)}):Play() end)
        createFeatureButton(resizeContainer, "重置尺寸", false, function() UI_WIDTH, UI_HEIGHT = 90, 160 updateUISizes() end, true)
        local styleContainer = Instance.new("Frame")
        styleContainer.Size, styleContainer.BackgroundTransparency, styleContainer.ClipsDescendants, styleContainer.Parent = UDim2.new(1, 0, 0, 0), 1, true, subScroll
        Instance.new("UIListLayout", styleContainer).SortOrder = Enum.SortOrder.LayoutOrder
        createFeatureButton(subScroll, "主题", true, function() TweenService:Create(styleContainer, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = CategoryStates["主题"] and UDim2.new(1, 0, 0, 90) or UDim2.new(1, 0, 0, 0)}):Play() end)
        styleContainer.LayoutOrder = 99
        local themes = {["Dark"]="暗黑", ["Glass"]="玻璃", ["Neon"]="霓虹", ["Midnight"]="午夜", ["DeepSea"]="深海"}
        for n, display in pairs(themes) do
            createFeatureButton(styleContainer, n, true, function() if CategoryStates[n] then CurrentTheme = n for k, _ in pairs(themes) do if k ~= n then CategoryStates[k] = false end end else CurrentTheme = "Dark" end updateAllThemes() end)
        end
    end

    for _, v in ipairs(items) do createFeatureButton(subScroll, v, false) end
    setupDraggableAndToggle(sub, subTitle, subScroll, false)
    SubUIFrames[name] = sub
end

local isResizing = false
local function initResizeLogic()
    local dragStart, startSize
    ResizeHandle.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isResizing, dragStart, startSize = true, input.Position, Vector2.new(UI_WIDTH, UI_HEIGHT) end end)
    UserInputService.InputChanged:Connect(function(input) if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then local delta = input.Position - dragStart UI_WIDTH, UI_HEIGHT = math.clamp(startSize.X + delta.X, 40, 400), math.clamp(startSize.Y + delta.Y, 80, 800) updateUISizes() end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isResizing = false end end)
end

