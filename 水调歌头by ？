-- ========== 地图自动化 ==========
spawn(function()
    while true do
        if CFG.AUTO_BELL then
            local leipzig = workspace:FindFirstChild("Leipzig")
            if leipzig and leipzig:FindFirstChild("Modes") then
                local modes = leipzig.Modes
                if modes:FindFirstChild("Objective") then
                    local objective = modes.Objective
                    if objective:FindFirstChild("BellInteract") then
                        local bell = objective.BellInteract
                        if bell:FindFirstChild("Interact") then
                            pcall(function() bell.Interact:FireServer() end)
                        end
                    end
                end
            end
        end
        if CFG.AUTO_BUCKET then
            local char = LocalPlayer.Character
            if char then
                local bucket = char:FindFirstChild("Water Bucket") or LocalPlayer.Backpack:FindFirstChild("Water Bucket")
                if bucket then
                    if bucket.Parent ~= char then bucket.Parent = char; wait(0.1) end
                    if bucket:FindFirstChild("RemoteEvent") then
                        pcall(function() bucket.RemoteEvent:FireServer("Throw") end)
                        spawn(function()
                            wait(0.2)
                            if bucket and bucket.Parent == char then bucket.Parent = LocalPlayer.Backpack end
                        end)
                    end
                end
            end
        end
        if CFG.AUTO_REPAIR_BRIDGE then
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local root = char.HumanoidRootPart
                local bridge = workspace:FindFirstChild("Berezina")
                if bridge then
                    bridge = bridge:FindFirstChild("Modes")
                    if bridge then bridge = bridge:FindFirstChild("Holdout")
                    if bridge then bridge = bridge:FindFirstChild("Bridge") end end end
                if bridge then
                    local nearest, nearestDist = nil, math.huge
                    for _, section in ipairs(bridge:GetChildren()) do
                        local posts = section:FindFirstChild("Posts")
                        if posts then
                            for _, part in ipairs(posts:GetChildren()) do
                                if part:IsA("BasePart") and part:FindFirstChild("ConstructHealth") then
                                    local d = (part.Position - root.Position).Magnitude
                                    if d < nearestDist then nearestDist = d; nearest = part.ConstructHealth end
                                end
                            end
                        end
                        local beam = section:FindFirstChild("Beam")
                        if beam and beam:FindFirstChild("ConstructHealth") then
                            local d = (beam.Position - root.Position).Magnitude
                            if d < nearestDist then nearestDist = d; nearest = beam.ConstructHealth end
                        end
                        for _, joists in ipairs(section:GetChildren()) do
                            if joists.Name == "Joists" and joists:FindFirstChild("ConstructHealth") then
                                local d = (joists.Position - root.Position).Magnitude
                                if d < nearestDist then nearestDist = d; nearest = joists.ConstructHealth end
                            end
                        end
                    end
                    if nearest and nearestDist < 20 then
                        local hammer = LocalPlayer.Backpack:FindFirstChild("Hammer") or LocalPlayer.Backpack:FindFirstChild("Claw Hammer")
                        if hammer and hammer:FindFirstChild("RemoteEvent") then
                            if hammer.Parent ~= char then hammer.Parent = char; wait(0.2) end
                            pcall(function() hammer.RemoteEvent:FireServer("Repair", nearest) end)
                        end
                    end
                end
            end
        end
        if CFG.AUTO_GET_LOGS then
            local waitTime = math.max(50, 1010 - CFG.AUTO_SPEED) / 1000
            local remoteEvent = workspace:FindFirstChild("Berezina")
            if remoteEvent then
                remoteEvent = remoteEvent:FindFirstChild("Modes")
                if remoteEvent then remoteEvent = remoteEvent:FindFirstChild("Holdout")
                if remoteEvent then remoteEvent = remoteEvent:FindFirstChild("Log")
                if remoteEvent then remoteEvent = remoteEvent:FindFirstChild("Log")
                if remoteEvent then remoteEvent = remoteEvent:FindFirstChild("Interact")
                if remoteEvent and remoteEvent:IsA("RemoteEvent") then pcall(function() remoteEvent:FireServer() end) end end end end end
            wait(waitTime)
        end
        if CFG.AUTO_PLACE_LOGS then
            local waitTime = math.max(50, 1010 - CFG.AUTO_SPEED) / 1000
            for _, prompt in pairs(workspace:GetDescendants()) do
                if prompt:IsA("ProximityPrompt") and prompt.Name == "PlaceLogProximityPrompt" then
                    pcall(function() fireproximityprompt(prompt) end)
                    wait(0.05)
                end
            end
            wait(waitTime)
        end
        wait(0.2)
    end
end)

