-- ========== 杀戮光环核心（从 GB 提取） ==========
local HeadCache = {}
local remotes = {}
local lastRemoteScan = 0
local zombiesFolder = Workspace:FindFirstChild("Zombies")
local function scanRemotes()
    table.clear(remotes)
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            for _, ch in ipairs(tool:GetChildren()) do
                if ch:IsA("RemoteEvent") then remotes[ch] = true end
            end
        end
    end
    lastRemoteScan = tick()
end

local function addHeadToCache(model)
    if not model or not model:IsA("Model") then return end
    local head = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
    if head and head:IsA("BasePart") then HeadCache[model] = head end
end

if zombiesFolder then
    for _, z in ipairs(zombiesFolder:GetChildren()) do if z:IsA("Model") then addHeadToCache(z) end end
    zombiesFolder.ChildAdded:Connect(function(c) if c:IsA("Model") then task.delay(0.03, function() addHeadToCache(c) end) end end)
end

local function fireSwing(remote)
    if remote then pcall(function() remote:FireServer("Swing", "Thrust") end) end
end
local function fireHit(remote, model, headPos)
    if not remote or not model or not headPos then return end
    pcall(function() remote:FireServer("HitZombie", model, headPos, true, Vector3.new(0,15,0), "Head", Vector3.new(0,1,0)) end)
end

local function isInFOV(pos)
    if not CFG.KILLAURA_FOV_ENABLED then return true end
    local cam = Camera
    if not cam then return true end
    local camPos = cam.CFrame.Position
    local camLook = cam.CFrame.LookVector
    local dir = (pos - camPos)
    local dist = dir.Magnitude
    if dist == 0 then return true end
    local dot = dir.Unit:Dot(camLook)
    return dot >= math.cos(math.rad(CFG.KILLAURA_FOV_SIZE / 2))
end

local function getTargetsInRange(range, hrpPos)
    local rangeSq = range * range
    local targets = {}
    for model, head in pairs(HeadCache) do
        if not (model and model.Parent and head and head.Parent) then HeadCache[model] = nil continue end
        local hum = model:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local pos = head.Position
        if (pos - hrpPos).MagnitudeSquared <= rangeSq and isInFOV(pos) then
            table.insert(targets, {model = model, head = head, headPos = pos})
        end
    end
    table.sort(targets, function(a,b) return (a.headPos - hrpPos).MagnitudeSquared < (b.headPos - hrpPos).MagnitudeSquared end)
    return targets
end

local killAuraLoopId = 0
task.spawn(function()
    while true do
        task.wait(0.05)
        if not CFG.KILLAURA_ENABLED then continue end
        killAuraLoopId = killAuraLoopId + 1
        local loopId = killAuraLoopId
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        if tick() - lastRemoteScan > 1 then scanRemotes() end
        local targets = getTargetsInRange(CFG.KILLAURA_RANGE, hrp.Position)
        if #targets == 0 then continue end
        local maxTargets = math.max(1, math.floor(CFG.KILLAURA_MULTI_TARGET))
        for i = 1, math.min(#targets, maxTargets) do
            local entry = targets[i]
            if not entry then break end
            for remote in pairs(remotes) do
                task.spawn(function()
                    if not CFG.KILLAURA_ENABLED or loopId ~= killAuraLoopId then return end
                    for _ = 1, CFG.KILLAURA_SPAM_COUNT do
                        fireSwing(remote)
                        task.wait(0.01)
                        fireHit(remote, entry.model, entry.headPos)
                    end
                end)
            end
        end
    end
end)

-- 自动面向
local autoLookConn = nil
local function updateAutoLook()
    if not CFG.KILLAURA_AUTO_LOOK then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local targets = getTargetsInRange(30, hrp.Position)
    if #targets == 0 then return end
    local headPos = targets[1].headPos
    if not headPos then return end
    local direction = (headPos - hrp.Position)
    local flatDir = Vector3.new(direction.X, 0, direction.Z)
    if flatDir.Magnitude <= 0.01 then return end
    hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + flatDir)
end
local function manageAutoLook()
    if CFG.KILLAURA_AUTO_LOOK and not autoLookConn then
        autoLookConn = RunService.Heartbeat:Connect(updateAutoLook)
    elseif not CFG.KILLAURA_AUTO_LOOK and autoLookConn then
        autoLookConn:Disconnect(); autoLookConn = nil
    end
end

-- 杀戮光环目标ESP
local dots = {}
local function updateKillAuraESP()
    if not CFG.KILLAURA_TARGET_ESP then
        for _, d in pairs(dots) do if d then d.Visible = false end end
        return
    end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local targets = getTargetsInRange(CFG.KILLAURA_RANGE, hrp.Position)
    local maxDots = math.max(1, math.floor(CFG.KILLAURA_MULTI_TARGET))
    for i = 1, maxDots do
        local dot = dots[i]
        if not dot then
            dot = Drawing and Drawing.new("Circle") or nil
            if dot then
                dot.Color = Color3.fromRGB(255,0,0)
                dot.Thickness = 1
                dot.NumSides = 12
                dot.Radius = 5
                dot.Filled = true
                dot.Transparency = 1
                dot.Visible = false
                dots[i] = dot
            end
        end
        if dot then
            local targetPos
            if i <= #targets then targetPos = targets[i].headPos else targetPos = hrp.Position end
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPos)
            if onScreen then
                dot.Position = Vector2.new(screenPos.X, screenPos.Y)
                dot.Visible = true
            else dot.Visible = false end
        end
    end
    for i = maxDots+1, #dots do if dots[i] then dots[i].Visible = false end end
end

-- 杀戮光环FOV圆圈
local fovCircleDraw = Drawing and Drawing.new("Circle") or nil
local function updateFOVCircle()
    if not CFG.KILLAURA_FOV_VISIBLE or not fovCircleDraw then
        if fovCircleDraw then fovCircleDraw.Visible = false end
        return
    end
    local cam = Camera
    if not cam then return end
    local size = cam.ViewportSize
    local center = size / 2
    fovCircleDraw.Position = center
    local fovRad = math.rad(CFG.KILLAURA_FOV_SIZE)
    local camFovRad = math.rad(cam.FieldOfView)
    local radius = (math.tan(fovRad / 2) / math.tan(camFovRad / 2)) * (size.Y / 2)
    fovCircleDraw.Radius = radius
    fovCircleDraw.Visible = true
end

RunService.RenderStepped:Connect(function()
    updateKillAuraESP()
    updateFOVCircle()
end)

