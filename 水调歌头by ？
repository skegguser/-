    createSubWindow("界面设置", {})
end

RunService.RenderStepped:Connect(function()
    local color = Color3.fromHSV(tick() % 5 / 5, 0.7, 1)
    for _, s in ipairs(UIStrokes) do if s and s.Parent then s.Color = color end end
    if UseRainbowTitle then local rainbow = Color3.fromHSV(tick() % 3 / 3, 0.8, 1) for _, t in ipairs(AllTitles) do t.TextColor3 = rainbow end end
    if MainFrame.Visible then
        local currentX, lastSub = 4, nil
        for _, sub in ipairs(ActiveSubUIs) do sub.Visible = true if LockSubUIs then sub.Position = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset + UI_WIDTH + currentX, MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset) currentX = currentX + UI_WIDTH + 4 end if sub.Visible and sub.Size.Y.Offset > BAR_HEIGHT + 5 then lastSub = sub end end
        if ResizeHandle.Visible then ResizeHandle.Parent, ResizeHandle.Position = lastSub or MainFrame, UDim2.new(1, 0, 1, 0) end
    else for _, sub in ipairs(ActiveSubUIs) do sub.Visible = false end ResizeHandle.Parent = nil end
end)

