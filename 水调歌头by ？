Instance.new("UICorner", speedEnhanceContainer)
local speedEnhanceLabel = Instance.new("TextLabel", speedEnhanceContainer)
speedEnhanceLabel.Size = UDim2.new(1,0,0,18)
speedEnhanceLabel.BackgroundTransparency = 1
speedEnhanceLabel.Text = "Speed: " .. SPEED_ENHANCE_VALUE
speedEnhanceLabel.TextColor3 = Color3.new(1,1,1)
speedEnhanceLabel.Font = "SourceSansBold"
speedEnhanceLabel.TextSize = 11
local speedEnhanceSlider = Instance.new("Frame", speedEnhanceContainer)
speedEnhanceSlider.Size = UDim2.new(0.8, 0, 0, 4)
speedEnhanceSlider.Position = UDim2.new(0.1, 0, 0.7, 0)
speedEnhanceSlider.BackgroundColor3 = Color3.fromRGB(60,60,70)
local speedEnhanceDot = Instance.new("TextButton", speedEnhanceSlider)
speedEnhanceDot.Size = UDim2.new(0, 10, 0, 10)
speedEnhanceDot.Position = UDim2.new((SPEED_ENHANCE_VALUE-16)/234, -5, 0.5, -5)
speedEnhanceDot.BackgroundColor3 = Color3.fromRGB(100,100,255)
speedEnhanceDot.Text = ""
Instance.new("UICorner", speedEnhanceDot).CornerRadius = UDim.new(1,0)
local function updateSpeedEnhance(input)
    local pos = math.clamp((input.Position.X - speedEnhanceSlider.AbsolutePosition.X) / speedEnhanceSlider.AbsoluteSize.X, 0, 1)
    speedEnhanceDot.Position = UDim2.new(pos, -5, 0.5, -5)
    SPEED_ENHANCE_VALUE = math.floor(16 + (pos * 234))
    speedEnhanceLabel.Text = "Speed: " .. SPEED_ENHANCE_VALUE
    if SPEED_ENHANCE_ON then
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.WalkSpeed = SPEED_ENHANCE_VALUE end
    end
end
local speedEnhanceDragging = false
