local function createBtn(parent, name, callback)
    local b = Instance.new("TextButton", parent); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundColor3 = Color3.fromRGB(35,35,45); b.Text = name .. " [关]"; b.TextColor3 = Color3.new(0.8,0.8,0.8); b.Font = "SourceSansBold"; b.TextSize = 12
    Instance.new("UICorner", b); local s = false; b.MouseButton1Click:Connect(function() s = not s; b.Text = name .. (s and " [开]" or " [关]"); b.BackgroundColor3 = s and Color3.fromRGB(50, 130, 80) or Color3.fromRGB(35,35,45); callback(s) end)
    return b
end
