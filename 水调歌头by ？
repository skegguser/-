    local anyNear, currentTargets = false, {}
    for _, obj in ipairs(Camera:GetChildren()) do
        for name, config in pairs(ESP_CONFIGS) do
            if activeStates[name] and config.check(obj) then
                currentTargets[obj] = true; createESP(obj, config.color, name)
                if config.alert and activeStates["自爆提醒"] and char and char:FindFirstChild("HumanoidRootPart") then
