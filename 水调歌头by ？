    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 15)

    local Title = Instance.new("TextLabel", MainFrame)
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.BackgroundTransparency = 1
    Title.Text = "官方飞行"
    Title.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    Title.TextSize = 12

    local SpeedInput = Instance.new("TextBox", MainFrame)
    SpeedInput.Size = UDim2.new(0, 140, 0, 30)
    SpeedInput.Position = UDim2.new(0.5, -70, 0, 40)
    SpeedInput.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    SpeedInput.Text = "35"
    SpeedInput.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", SpeedInput).CornerRadius = UDim.new(0, 8)

    local Toggle = Instance.new("TextButton", MainFrame)
    Toggle.Size = UDim2.new(0, 140, 0, 40)
    Toggle.Position = UDim2.new(0.5, -70, 0, 85)
    Toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    Toggle.Text = "丝滑飞行: OFF"
    Toggle.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0, 10)

    local isFlying = false
    local flySpeed = 35
    local bv, bg, animCache, flyCtrl

    local function getFlyControl()
        if flyCtrl then return flyCtrl end
        local success, module = pcall(function()
            return require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule")):GetControls()
        end)
        if success then flyCtrl = module; return module end
        return nil
    end

    local function startFly()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local animate = char:FindFirstChild("Animate")
        if animate then animCache = animate; animate.Parent = nil end
        bv = Instance.new("BodyVelocity", hrp)
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bg = Instance.new("BodyGyro", hrp)
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        bg.P = 8000
        spawn(function()
            local ctrl = getFlyControl()
            while isFlying and char and char.Parent do
                if ctrl then
                    local moveVec = ctrl:GetMoveVector()
                    local camCF = Camera.CFrame
                    local moveDir = (camCF.LookVector * -moveVec.Z) + (camCF.RightVector * moveVec.X)
                    if moveVec.Magnitude > 0 then
                        bv.Velocity = moveDir.Unit * flySpeed
                        bg.CFrame = CFrame.new(Vector3.zero, moveDir)
                    else
                        bv.Velocity = Vector3.new(0, 0.01, 0)
                        bg.CFrame = CFrame.new(Vector3.zero, Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z))
                    end
                    hum:ChangeState(Enum.HumanoidStateType.Climbing)
                end
                RunService.RenderStepped:Wait()
            end
            if animCache then animCache.Parent = char end
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
        end)
    end

    local function stopFly()
        isFlying = false
        if bv then bv:Destroy(); bv=nil end
        if bg then bg:Destroy(); bg=nil end
        if animCache and LocalPlayer.Character then
            animCache.Parent = LocalPlayer.Character
            animCache = nil
        end
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum and hum:GetState() == Enum.HumanoidStateType.Climbing then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end

    Toggle.MouseButton1Click:Connect(function()
        isFlying = not isFlying
        flySpeed = tonumber(SpeedInput.Text) or 35
        Toggle.Text = isFlying and "已开启 - 运行中" or "丝滑飞行: OFF"
        TweenService:Create(Toggle, TweenInfo.new(0.3), {BackgroundColor3 = isFlying and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(60, 60, 60)}):Play()
        if isFlying then startFly() else stopFly() end
    end)

    -- 拖动逻辑
    local dragging, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end
    end)

    -- 关闭和最小化按钮
    local function topBtn(t, x, c, f)
        local b = Instance.new("TextButton", MainFrame)
        b.Size = UDim2.new(0, 25, 0, 25)
        b.Position = UDim2.new(1, x, 0, 5)
        b.Text = t
        b.BackgroundColor3 = c
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        b.MouseButton1Click:Connect(f)
    end
    topBtn("×", -30, Color3.fromRGB(150,50,50), function() isFlying = false; flyScreenGui:Destroy(); flyScreenGui=nil end)
    topBtn("-", -60, Color3.fromRGB(70,70,70), function()
        local collapsed = MainFrame.Size.Y.Offset < 140
        local targetH = collapsed and 140 or 35
        TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 180, 0, targetH)}):Play()
        Toggle.Visible = collapsed
        SpeedInput.Visible = collapsed
    end)

    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame:TweenSize(UDim2.new(0, 180, 0, 140), "Out", "Back", 0.5)
end

-- ========== 杀戮光环（近战） ==========
local function getNearestZombie(range)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil
    local closest, bestDist = nil, range
    local zombies = Workspace:FindFirstChild("Zombies")
    if not zombies then return nil
    for _, z in ipairs(zombies:GetChildren()) do
        if z:IsA("Model") then
            local zr = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
            local hum = z:FindFirstChildOfClass("Humanoid")
            if zr and hum and hum.Health > 0 then
                local d = (hrp.Position - zr.Position).Magnitude
                if d < bestDist then
                    closest = z
                    bestDist = d
                end
            end
        end
    end
    return closest
end

local function getWeaponRemote()
    local char = LocalPlayer.Character
    if not char then return nil
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return nil
    return tool:FindFirstChild("RemoteEvent")
end

spawn(function()
    while true do
        wait(0.1)
        if CFG.KILLAURA then
            local target = getNearestZombie(CFG.KILLAURA_RANGE)
            if target then
                local remote = getWeaponRemote()
                if remote then
                    local head = target:FindFirstChild("Head") or target:FindFirstChild("HumanoidRootPart")
                    if head then
                        pcall(function()
                            remote:FireServer("Swing", "Thrust")
                            wait(0.05)
                            remote:FireServer("HitZombie", target, head.Position, true, Vector3.new(0,15,0), "Head", Vector3.new(0,1,0))
                        end)
                    end
                end
            end
        end
    end
end)

-- 自动面向
spawn(function()
    while true do
        wait(0.05)
        if CFG.AUTO_FACE then
            local target = getNearestZombie(CFG.KILLAURA_RANGE)
            if target then
                local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Torso")
                if hrp and tRoot then
                    hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(tRoot.Position.X, hrp.Position.Y, tRoot.Position.Z))
                end
            end
        end
    end
end)

-- 僵尸透视（Highlight）
local espHighlights = {}
local function updateESP()
    if not CFG.ESP then
        for _, hl in pairs(espHighlights) do if hl then hl:Destroy() end end
        table.clear(espHighlights)
        return
    end
    local zombies = Workspace:FindFirstChild("Zombies")
    if not zombies then return
    for _, z in ipairs(zombies:GetChildren()) do
        if z:IsA("Model") and not espHighlights[z] then
            local hl = Instance.new("Highlight", z)
            hl.FillColor = Color3.fromRGB(255, 100, 0)
            hl.FillTransparency = 0.5
            hl.OutlineColor = Color3.new(1,1,1)
            espHighlights[z] = hl
        end
    end
    for z, hl in pairs(espHighlights) do
        if not z.Parent then hl:Destroy(); espHighlights[z] = nil end
    end
end
spawn(function()
    while true do
        updateESP()
        wait(0.25)
    end
end)

