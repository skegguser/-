RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum and not FLY_ENABLED then
        hum.WalkSpeed = LOOP_SPEED_VAL
    end
    
    if FULL_BRIGHT_ON then 
        Lighting.Ambient = Color3.new(1,1,1)
        Lighting.OutdoorAmbient = Color3.new(1,1,1)
        Lighting.Brightness = 2 
        Lighting.ClockTime = 14
    end

    -- 近战攻击
    if KILLAURA_ON and currentTarget and currentRemote and currentConfig then
        local now = tick()
        if now - lastAttackTime >= currentConfig.delay then
            local head = currentTarget:FindFirstChild("Head") or currentTarget:FindFirstChild("HumanoidRootPart")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if head and hrp then
                local dir = (head.Position - hrp.Position).Unit
                pcall(function() currentRemote:FireServer("Swing", currentConfig.swing); currentRemote:FireServer("HitZombie", currentTarget, head.Position, true, dir * 15, "Head", dir) end)
                lastAttackTime = now
            end
        end
    end
    -- 肘击
    for weaponType, config in pairs(ELBOW_CONFIGS) do if activeStates["肘击_" .. weaponType] then local target = findElbowTarget(config.range); if target then lastElbowTimes[weaponType] = attackElbow(target, weaponType, lastElbowTimes[weaponType] or 0, config.delay) end end end
    -- 自动面向
    if AUTO_FACE_ON and currentTarget then local hrp = char and char:FindFirstChild("HumanoidRootPart"); local tRoot = currentTarget:FindFirstChild("HumanoidRootPart") or currentTarget:FindFirstChild("Torso"); if hrp and tRoot then hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(tRoot.Position.X, hrp.Position.Y, tRoot.Position.Z)) end end
    
    -- ESP 更新
    local anyNear, currentTargets = false, {}
    for _, obj in ipairs(Camera:GetChildren()) do
        for name, config in pairs(ESP_CONFIGS) do
            if activeStates[name] and config.check(obj) then
                currentTargets[obj] = true; createESP(obj, config.color, name)
                if config.alert and activeStates["自爆提醒"] and char and char:FindFirstChild("HumanoidRootPart") then
                    local t = obj:FindFirstChild("Torso") or obj:FindFirstChild("HumanoidRootPart")
                    if t and (char.HumanoidRootPart.Position - t.Position).Magnitude <= ALERT_RANGE then anyNear = true end
                end
            end
        end
    end
    alertFrame.Visible = anyNear
    for m, d in pairs(espHighlights) do if not currentTargets[m] or not m:IsDescendantOf(workspace) then d.hl:Destroy(); d.gui:Destroy(); espHighlights[m] = nil end end
end)

