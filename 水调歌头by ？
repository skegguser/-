local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if GUN_SILENT_AIM and method == "Raycast" and (self == Workspace or self.ClassName == "Workspace") and not checkcaller() and silentAimCurrentTarget then
