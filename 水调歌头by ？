local function fireSwing(remote)
    if remote and remote:IsA("RemoteEvent") then
        pcall(function() remote:FireServer("Swing", "Thrust") end)
    end
end

local function fireHit(remote, model, partPos)
    if not (remote and remote:IsA("RemoteEvent") and model and partPos) then return end
    pcall(function()
        remote:FireServer("HitZombie", model, partPos, true, Vector3.new(0, 15, 0), "Head", Vector3.new(0, 1, 0))
    end)
end

local function isInFOV(pos)
    local cam = Camera
    if not cam then return false end
    local camPos = cam.CFrame.Position
    local camLook = cam.CFrame.LookVector
    local dir = (pos - camPos)
    local dist = dir.Magnitude
    if dist == 0 then return true end
    local unit = dir / dist
    local dot = unit:Dot(camLook)
    return dot >= math.cos(math.rad(FOVSize / 2))
end

local function getTargetsInRange(range, hrpPos, useFOV)
    local rangeSq = range * range
    local targets = {}
    if not hrpPos then return targets end
    for model, part in pairs(HeadCache) do
        if not (model and model.Parent and part and part.Parent) then
            HeadCache[model] = nil
            continue
        end
        if not AttackBarrels and isBomber(model) then continue end
        local hum = model:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local state = model:FindFirstChild("State")
        if state and state.Value == "Spawn" then continue end
        local ok, pos = pcall(function() return part.Position end)
        if not ok or not pos then continue end
        local d2 = distSqVec3(pos, hrpPos)
        if d2 <= rangeSq then
            if not useFOV or isInFOV(pos) then
                targets[#targets+1] = { model = model, part = part, d2 = d2, partPos = pos }
            end
        end
    end
    table.sort(targets, function(a, b) return a.d2 < b.d2 end)
    return targets
end

local function autoEquipBestWeapon()
    if not AutoEquip then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if char:FindFirstChildOfClass("Tool") then return end
    local zombieNearby = false
    local zombies = Workspace:FindFirstChild("Zombies")
    if zombies then
        for _, z in ipairs(zombies:GetChildren()) do
            if z:IsA("Model") then
                if not AttackBarrels and isBomber(z) then continue end
                local zRoot = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
                local hum = z:FindFirstChildOfClass("Humanoid")
                if zRoot and hum and hum.Health > 0 then
                    if (hrp.Position - zRoot.Position).Magnitude <= EQUIP_RANGE then
                        zombieNearby = true
                        break
                    end
                end
            end
        end
    end
    if zombieNearby then
        for _, weaponName in ipairs(WEAPON_PRIORITY) do
            local tool = LocalPlayer.Backpack:FindFirstChild(weaponName)
            if tool then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum:EquipTool(tool)
                    break
                end
            end
        end
    end
end

local function getElbowRemote(weaponName)
    local tool = LocalPlayer.Backpack:FindFirstChild(weaponName) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(weaponName))
    return tool and tool:FindFirstChild("RemoteEvent")
end

local function findElbowTarget(range)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local zombies = Workspace:FindFirstChild("Zombies")
    if not hrp or not zombies then return nil end
    local closest, bestDist = nil, range
    for _, z in pairs(zombies:GetChildren()) do
        if z:IsA("Model") then
            if not AttackBarrels and isBomber(z) then continue end
            local zHrp = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
            local hum = z:FindFirstChildOfClass("Humanoid")
            if zHrp and hum and hum.Health > 0 then
                local state = z:FindFirstChild("State")
                if state and state.Value == "Stunned" then continue end
                if state and state.Value == "Spawn" then continue end
                local d = (hrp.Position - zHrp.Position).Magnitude
                if d < bestDist then
                    closest = z
                    bestDist = d
                end
            end
        end
    end
    return closest
end

local function performElbowAttack(weaponName, target)
    local remote = getElbowRemote(weaponName)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local tRoot = target:FindFirstChild("HumanoidRootPart") or target:FindFirstChild("Head")
    if not remote or not root or not tRoot then return end
    pcall(function()
        if weaponName == "Axe" then
            remote:FireServer("Equip", root)
            remote:FireServer("BraceBlock")
            remote:FireServer("FeedbackStun", target, tRoot.Position)
            remote:FireServer("StopBraceBlock")
        else
            remote:FireServer("Shove")
            remote:FireServer("FeedbackStun", target, tRoot.Position)
        end
    end)
end

