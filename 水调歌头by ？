local WEAPON_DB = {
    ["Stake"] = {range = 13, delay = 0.01, swing = "Over", mult = 12},
    ["Hand Axe"] = {range = 14, delay = 0.01, swing = "Over", mult = 12},
    ["Boarding Axe"] = {range = 15, delay = 0.01, swing = "Over", mult = 15},
    ["Heavy Sabre"] = {range = 15, delay = 0.01, swing = "Thrust", mult = 18},
    ["Sabre"] = {range = 15, delay = 0.01, swing = "Thrust", mult = 18},
