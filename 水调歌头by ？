local espHighlights = {}
local function updateZombieESP()
    if not CFG.ESP_BOMBER and not CFG.ESP_CUIRASSIER and not CFG.ESP_RUNNER and not CFG.ESP_ZAPPER and not CFG.ESP_IGNITER then
        for _, hl in pairs(espHighlights) do if hl then hl:Destroy() end end
        table.clear(espHighlights)
        return
    end
    local zombies = Workspace:FindFirstChild("Zombies")
    if not zombies then return
    local enabledTypes = {}
    if CFG.ESP_BOMBER then enabledTypes.Bomber = true end
    if CFG.ESP_CUIRASSIER then enabledTypes.Cuirassier = true end
    if CFG.ESP_RUNNER then enabledTypes.Runner = true end
    if CFG.ESP_ZAPPER then enabledTypes.Zapper = true end
    if CFG.ESP_IGNITER then enabledTypes.Igniter = true end
    for _, z in ipairs(zombies:GetChildren()) do
        if z:IsA("Model") then
            local espType = nil
            if enabledTypes.Bomber and z:FindFirstChild("Barrel") then espType = "Bomber"
            elseif enabledTypes.Cuirassier and z:FindFirstChild("Sword") then espType = "Cuirassier"
            elseif enabledTypes.Runner and z:FindFirstChild("Eye") and not z:FindFirstChild("Axe") then espType = "Runner"
            elseif enabledTypes.Zapper and z:FindFirstChild("Axe") then espType = "Zapper"
            elseif enabledTypes.Igniter and z:FindFirstChild("Whale Oil Lantern") then espType = "Igniter" end
            if espType then
                if not espHighlights[z] then
                    local hl = Instance.new("Highlight", z)
                    hl.FillColor = ({
                        Bomber = Color3.fromRGB(255,180,60),
                        Cuirassier = Color3.fromRGB(0,200,255),
                        Runner = Color3.fromRGB(255,0,0),
                        Zapper = Color3.fromRGB(0,255,0),
                        Igniter = Color3.fromRGB(255,255,0),
                    })[espType]
                    hl.FillTransparency = CFG.ESP_CHAMS_TRANSPARENCY
                    hl.OutlineColor = Color3.new(1,1,1)
                    espHighlights[z] = hl
                end
            end
        end
    end
    for z, hl in pairs(espHighlights) do
        if not z.Parent then hl:Destroy(); espHighlights[z] = nil end
    end
end
spawn(function()
    while true do
        updateZombieESP()
        wait(0.25)
    end
end)

-- 玩家透视
local playerESPData = {}
local function updatePlayerESP()
    if not (CFG.PLAYER_CHAMS or CFG.PLAYER_BILLBOARD) then
        for _, data in pairs(playerESPData) do
            if data.hl then data.hl:Destroy() end
            if data.bb then data.bb:Destroy() end
        end
        table.clear(playerESPData)
        return
    end
    local localChar = LocalPlayer.Character
    local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char or not char.Parent then
            if playerESPData[player] then
                if playerESPData[player].hl then playerESPData[player].hl:Destroy() end
                if playerESPData[player].bb then playerESPData[player].bb:Destroy() end
                playerESPData[player] = nil
            end
            continue
        end
        local head = char:FindFirstChild("Head")
        if not head then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end
        local data = playerESPData[player]
        if not data then
            data = {}
            if CFG.PLAYER_CHAMS then
                data.hl = Instance.new("Highlight")
                data.hl.Adornee = char
                data.hl.FillColor = Color3.fromRGB(0,255,0)
                data.hl.FillTransparency = 0.45
                data.hl.OutlineColor = Color3.new(1,1,1)
                data.hl.Parent = char
            end
            if CFG.PLAYER_BILLBOARD then
                data.bb = Instance.new("BillboardGui")
                data.bb.Adornee = head
                data.bb.Size = UDim2.new(0, 120, 0, 60)
                data.bb.StudsOffset = Vector3.new(0, 3, 0)
                data.bb.AlwaysOnTop = true
                local frame = Instance.new("Frame", data.bb)
                frame.Size = UDim2.new(1,0,1,0)
                frame.BackgroundColor3 = Color3.fromRGB(0,0,0)
                frame.BackgroundTransparency = 0.6
                local nameLbl = Instance.new("TextLabel", frame)
                nameLbl.Size = UDim2.new(1,0,0.3,0)
                nameLbl.BackgroundTransparency = 1
                nameLbl.Text = player.Name
                nameLbl.TextColor3 = Color3.new(1,1,1)
                nameLbl.TextScaled = true
                local healthLbl = Instance.new("TextLabel", frame)
                healthLbl.Size = UDim2.new(1,0,0.3,0)
                healthLbl.Position = UDim2.new(0,0,0.3,0)
                healthLbl.BackgroundTransparency = 1
                healthLbl.Text = "生命值: " .. math.floor(hum.Health) .. "/" .. hum.MaxHealth
                healthLbl.TextColor3 = Color3.fromRGB(0,255,0)
                healthLbl.TextScaled = true
                data.labels = {health = healthLbl}
                if CFG.SHOW_INFECTED then
                    local infLbl = Instance.new("TextLabel", frame)
                    infLbl.Size = UDim2.new(1,0,0.3,0)
                    infLbl.Position = UDim2.new(0,0,0.6,0)
                    infLbl.BackgroundTransparency = 1
                    infLbl.Text = "感染: 0/100"
                    infLbl.TextColor3 = Color3.fromRGB(255,255,0)
                    infLbl.TextScaled = true
                    data.labels.inf = infLbl
                end
                data.bb.Parent = char
            end
            playerESPData[player] = data
        end
        if CFG.PLAYER_CHAMS and data.hl then
            local percent = hum.Health / hum.MaxHealth
            local r = math.floor(255 * (1 - percent))
            local g = math.floor(255 * percent)
            data.hl.FillColor = Color3.fromRGB(r, g, 0)
        end
        if CFG.PLAYER_BILLBOARD and data.labels and data.labels.health then
            data.labels.health.Text = "生命值: " .. math.floor(hum.Health) .. "/" .. hum.MaxHealth
            local percent = hum.Health / hum.MaxHealth
            data.labels.health.TextColor3 = Color3.fromRGB(255 * (1 - percent), 255 * percent, 0)
            if localRoot and head then
                local dist = (localRoot.Position - head.Position).Magnitude
                data.bb.Enabled = dist <= 150
            end
            local wsPlayers = Workspace:FindFirstChild("Players")
            if wsPlayers and CFG.SHOW_INFECTED and data.labels.inf then
                local pf = wsPlayers:FindFirstChild(player.Name)
                if pf then
                    local us = pf:FindFirstChild("UserStates")
                    if us then
                        local infected = us:FindFirstChild("Infected")
                        if infected then
                            data.labels.inf.Text = "感染: " .. infected.Value .. "/100"
                        end
                    end
                end
            end
        end
    end
end
spawn(function()
    while true do
        updatePlayerESP()
        wait(0.2)
    end
end)

-- 低生命通知和被抓/压制通知
local lowHealthNotified = {}
local grabbedNotified = {}
spawn(function()
    while true do
        if CFG.NOTIFY_LOW_HEALTH or CFG.NOTIFY_GRABBED_PINNED then
            for _, player in ipairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                local char = player.Character
                if not char then continue end
                local hum = char:FindFirstChildOfClass("Humanoid")
                if not hum then continue end
                if CFG.NOTIFY_LOW_HEALTH then
                    local percent = hum.Health / hum.MaxHealth
                    if percent < 0.25 and not lowHealthNotified[player] then
                        lowHealthNotified[player] = true
                        pcall(function() print("[通知] " .. player.Name .. " 正在濒死!") end)
                    elseif percent >= 0.25 then lowHealthNotified[player] = false end
                end
                if CFG.NOTIFY_GRABBED_PINNED then
                    local wsPlayers = Workspace:FindFirstChild("Players")
                    if wsPlayers then
                        local pf = wsPlayers:FindFirstChild(player.Name)
                        if pf then
                            local us = pf:FindFirstChild("UserStates")
                            if us then
                                local grabbed = us:FindFirstChild("Grabbed") and us.Grabbed.Value ~= 0
                                local pin = us:FindFirstChild("Pin") and us.Pin.Value ~= ""
                                if (grabbed or pin) and not grabbedNotified[player] then
                                    grabbedNotified[player] = true
                                    pcall(function() print("[通知] " .. player.Name .. " 正被抓或压制!") end)
                                elseif not (grabbed or pin) then grabbedNotified[player] = false end
                            end
                        end
                    end
                end
            end
        end
        wait(0.5)
    end
end)

