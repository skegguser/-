    ["Spontoon"] = {range = 25, delay = 0.01, swing = "Thrust", mult = 12},
    ["Officer's Sabre"] = {range = 15, delay = 0.01, swing = "Thrust", mult = 15}
}
local lastMeleeAttackTime = 0
local meleeCurrentTarget = nil
local meleeCurrentRemote = nil
local meleeCurrentConfig = nil

local function isDangerousCore(obj)
    if not obj or not obj:IsA("Model") then return true end
    local current = obj
    while current and current ~= workspace do
        if current.Name == "m_Zombie" or current:FindFirstChild("Barrel", true) or current.Parent == workspace:FindFirstChild("Camera") then return true end
        current = current.Parent
    end
    local cam = workspace:FindFirstChild("Camera")
    if cam then
        for _, b in ipairs(cam:GetChildren()) do
            if b.Name == "m_Zombie" and b:FindFirstChild("Barrel", true) then
                local bRoot = b:FindFirstChild("HumanoidRootPart") or b:FindFirstChild("Torso")
                local objPos = (obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso") or {Position = Vector3.new(9e9,9e9,9e9)}).Position
                if bRoot and (bRoot.Position - objPos).Magnitude < 4 then return true end
            end
        end
    end
    return false
end

local function scanMeleeTarget()
    if not CFG.MELEE_KILLAURA then meleeCurrentTarget = nil return end
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local closest, minDist = nil, 25
    local folders = {workspace:FindFirstChild("Zombies"), workspace:FindFirstChild("Camera")}
    for _, f in pairs(folders) do 
        if f then 
            for _, z in ipairs(f:GetChildren()) do
                if z:IsA("Model") and not isDangerousCore(z) then
                    local zr = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
                    local hum = z:FindFirstChildOfClass("Humanoid")
                    if zr and hum and hum.Health > 0 then 
                        local d = (hrp.Position - zr.Position).Magnitude 
                        if d < minDist then closest, minDist = z, d end 
                    end
                end
            end
        end 
    end
    meleeCurrentTarget = closest
end

local function autoEquipMeleeWeapon()
    if not CFG.MELEE_AUTO_EQUIP then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if char:FindFirstChildOfClass("Tool") then return end
    local zombieNearby = false
    local zombies = workspace:FindFirstChild("Zombies")
    if zombies then
        for _, z in ipairs(zombies:GetChildren()) do
            if z:IsA("Model") and not isDangerousCore(z) then
                local zRoot = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
                local hum = z:FindFirstChildOfClass("Humanoid")
                if zRoot and hum and hum.Health > 0 then
                    local dist = (hrp.Position - zRoot.Position).Magnitude
                    if dist <= 30 then zombieNearby = true; break end
                end
            end
        end
    end
    if zombieNearby then
        for name, _ in pairs(WEAPON_DB) do
            local tool = LocalPlayer.Backpack:FindFirstChild(name)
            if tool then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then hum:EquipTool(tool); break end
            end
        end
    end
end

task.spawn(function()
    while true do
        if CFG.MELEE_KILLAURA then
            scanMeleeTarget()
            autoEquipMeleeWeapon()
            local char = LocalPlayer.Character
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool and WEAPON_DB[tool.Name] then
                    meleeCurrentRemote = tool:FindFirstChild("RemoteEvent")
                    meleeCurrentConfig = WEAPON_DB[tool.Name]
                else
                    meleeCurrentRemote = nil
                    meleeCurrentConfig = nil
                end
            end
            if meleeCurrentTarget and meleeCurrentRemote and meleeCurrentConfig then
                local now = tick()
                if now - lastMeleeAttackTime >= meleeCurrentConfig.delay then
                    local head = meleeCurrentTarget:FindFirstChild("Head") or meleeCurrentTarget:FindFirstChild("HumanoidRootPart")
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if head and hrp then
                        local dir = (head.Position - hrp.Position).Unit
                        pcall(function()
                            meleeCurrentRemote:FireServer("Swing", meleeCurrentConfig.swing)
                            meleeCurrentRemote:FireServer("HitZombie", meleeCurrentTarget, head.Position, true, dir * 15, "Head", dir)
                        end)
                        lastMeleeAttackTime = now
                        if CFG.MELEE_JUMP_SWING then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum and hum.FloorMaterial ~= Enum.Material.Air then hum.Jump = true end
                        end
                    end
                end
            end
            if CFG.MELEE_AUTO_FACE and meleeCurrentTarget then
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local tRoot = meleeCurrentTarget:FindFirstChild("HumanoidRootPart") or meleeCurrentTarget:FindFirstChild("Torso")
                if hrp and tRoot then
                    hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(tRoot.Position.X, hrp.Position.Y, tRoot.Position.Z))
                end
            end
        end
        task.wait(0.05)
    end
end)

