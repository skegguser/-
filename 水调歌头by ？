local function isWorldPosInFov(worldPos)
    if not CFG.USE_FOV then return true end
    local cam = Workspace.CurrentCamera
    if not cam then return true end
    local screenPos, onScreen = cam:WorldToViewportPoint(worldPos)
    if not onScreen then return false end
    local centerVec = getFovScreenCenter()
    local dist = (Vector2.new(screenPos.X, screenPos.Y) - centerVec).Magnitude
    local sizePx = (math.clamp(CFG.FOV_SIZE, 10, 120) / 40) * 250
    return dist <= (sizePx / 2)
end

local function isGun(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local animFolder = tool:FindFirstChild("Animations")
    return animFolder and (animFolder:FindFirstChild("Aim") or animFolder:FindFirstChild("Aiming"))
end

local function getShotsLoadedForTool(tool)
    if not tool then return 0 end
    local s = tool:FindFirstChild("ShotsLoaded")
    if s and (s:IsA("IntValue") or s:IsA("NumberValue")) then return s.Value end
    return 0
end

local function findRemoteForTool(tool)
    if not tool then return nil end
    return tool:FindFirstChild("RemoteEvent")
end

local function hasClearShotOnPart(originPos, aimPart, targetModel)
    if not CFG.GUN_WALL_CHECK then return true end
    if not originPos or not aimPart then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, targetModel, BeamFolder}
    local dir = aimPart.Position - originPos
    local result = workspace:Raycast(originPos, dir, params)
    return result == nil
end

local function getPredictedAimPosition(part)
    if not part then return nil end
    local pos = part.Position
    if CFG.PREDICTION <= 0 then return pos end
    local vel = part.AssemblyLinearVelocity or Vector3.new(0, 0, 0)
    return pos + vel * CFG.PREDICTION
end

local function performReload(tool, targetShots)
    if reloadInProgress[tool] then return end
    reloadInProgress[tool] = true
    local remote = findRemoteForTool(tool)
    if not remote then reloadInProgress[tool] = nil return end
    if targetShots > 1 then pcall(function() remote:FireServer("StartReload") end) task.wait(0.1) end
    local attempts = 0
    while attempts < 50 do
        if getShotsLoadedForTool(tool) >= targetShots then
            pcall(function() tool.Parent = LocalPlayer.Backpack end)
            task.wait(0.02)
            pcall(function() tool.Parent = LocalPlayer.Character end)
            break
        end
        pcall(function() remote:FireServer("Reload") end)
        task.wait(0.05)
        attempts = attempts + 1
    end
    reloadInProgress[tool] = nil
end

local function tryReloadTool(tool)
    if not CFG.AUTO_RELOAD or not isGun(tool) then return end
    local shots = getShotsLoadedForTool(tool)
    if tool.Name == "Nock Gun" and shots < 7 then
        task.spawn(performReload, tool, 7)
    elseif (tool.Name == "Double Barrel Pistol" or tool.Name == "Horse Artillery Pistol") and shots == 0 then
        task.spawn(performReload, tool, 2)
    elseif shots == 0 then
        task.spawn(performReload, tool, 1)
    end
end

local function getNearestZombie(range)
    local cam = Workspace.CurrentCamera
    local originPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position or cam.CFrame.Position
    if not originPos then return nil end
    local bestPart, bestModel, bestDist = nil, nil, range
    local zombiesFolder = Workspace:FindFirstChild("Zombies")
    if not zombiesFolder then return nil end
    for _, model in ipairs(zombiesFolder:GetDescendants()) do
        if model:IsA("Model") and not model:FindFirstChild("Spawn") then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local aimPart = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
                if aimPart then
                    local aimPos = getPredictedAimPosition(aimPart)
                    if isWorldPosInFov(aimPos) then
                        local d = (aimPos - originPos).Magnitude
                        if d <= bestDist and hasClearShotOnPart(originPos, aimPart, model) then
                            bestPart, bestModel, bestDist = aimPart, model, d
                        end
                    end
                end
            end
        end
    end
    return bestPart, bestModel
end

