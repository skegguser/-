local function getBayonetDynamicHeight(distance)
    local optimalDist = 12
    local dropScale = 140
    local dynamic = CFG.BAYONET_BASE_HEIGHT - ((distance - optimalDist)^2 / dropScale)
    return math.clamp(dynamic, 0.2, CFG.BAYONET_BASE_HEIGHT)
end

local function isBayonetBehindWall(targetPart)
    local char = LocalPlayer.Character
    if not char or not targetPart then return true end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, workspace:FindFirstChild("Zombies"), workspace:FindFirstChild("Camera"), BeamFolder}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local origin = Camera.CFrame.Position
    local direction = targetPart.Position - origin
    local raycastResult = workspace:Raycast(origin, direction, raycastParams)
    return raycastResult ~= nil
end

local function getBayonetTarget()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, 0 end
    local closest, minDist = nil, CFG.BAYONET_RANGE
    local dangerZones = {}
    if not CFG.BAYONET_FACE_BOMBER then
        local folders = {workspace, workspace:FindFirstChild("Camera")}
        for _, f in pairs(folders) do
            if f then
                for _, m in ipairs(f:GetChildren()) do
                    if m:IsA("Model") and (m.Name:find("Bomber") or m:FindFirstChild("Barrel")) then
                        local p = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Barrel")
                        if p then table.insert(dangerZones, p.Position) end
                    end
                end
            end
        end
    end
    local targetFolders = {workspace:FindFirstChild("Zombies"), workspace:FindFirstChild("Camera")}
    for _, f in pairs(targetFolders) do
        if f then
            for _, z in ipairs(f:GetChildren()) do
                if z:IsA("Model") then
                    local head = z:FindFirstChild("Head")
                    local hum = z:FindFirstChildOfClass("Humanoid")
                    if head and hum and hum.Health > 0 then
                        local d = (hrp.Position - head.Position).Magnitude
                        if d < minDist then
                            local safe = true
                            for _, bPos in ipairs(dangerZones) do
                                if (head.Position - bPos).Magnitude < 6 then safe = false break end
                            end
                            local wallBlock = false
                            if CFG.BAYONET_WALL_CHECK then wallBlock = isBayonetBehindWall(head) end
                            if safe and not wallBlock then closest, minDist = head, d end
                        end
                    end
                end
            end
        end
    end
    return closest, minDist
end

