-- Resize 拖拽逻辑（修复）
local isResizing = false
local lastActiveFrame = nil
local dragStart, startSize
local function initResizeLogic()
    ResizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isResizing = true
            dragStart = input.Position
            startSize = Vector2.new(UI_WIDTH, UI_HEIGHT)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isResizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            UI_WIDTH = math.clamp(startSize.X + delta.X, 40, 400)
            UI_HEIGHT = math.clamp(startSize.Y + delta.Y, 80, 800)
            updateUISizes()
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isResizing = false
        end
    end)
end

-- 渲染循环中更新ResizeHandle的父级
RunService.RenderStepped:Connect(function()
    local color = Color3.fromHSV(tick() % 5 / 5, 0.7, 1)
    for _, s in ipairs(UIStrokes) do if s and s.Parent then s.Color = color end end
    if UseRainbowTitle then local rainbow = Color3.fromHSV(tick() % 3 / 3, 0.8, 1) for _, t in ipairs(AllTitles) do t.TextColor3 = rainbow end end
    if MainFrame.Visible then
        local currentX, lastSub = 4, nil
        for _, sub in ipairs(ActiveSubUIs) do 
            sub.Visible = true 
            if LockSubUIs then 
                sub.Position = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset + UI_WIDTH + currentX, MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset) 
                currentX = currentX + UI_WIDTH + 4 
            end 
            if sub.Visible and sub.Size.Y.Offset > BAR_HEIGHT + 5 then lastSub = sub end 
        end
        if ResizeHandle.Visible then 
            local targetFrame = lastSub or MainFrame
            lastActiveFrame = targetFrame
            ResizeHandle.Parent = targetFrame
            ResizeHandle.Position = UDim2.new(1, 0, 1, 0)
        else
            ResizeHandle.Parent = nil
        end
    else 
        for _, sub in ipairs(ActiveSubUIs) do sub.Visible = false end 
        ResizeHandle.Parent = nil
    end
end)

