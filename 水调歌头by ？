RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed = LOOP_SPEED_VAL end
    
    if FULL_BRIGHT_ON then 
        Lighting.Ambient = Color3.new(1,1,1)
        Lighting.OutdoorAmbient = Color3.new(1,1,1)
        Lighting.Brightness = 2 
        Lighting.ClockTime = 14
    end

    if KILLAURA_ON and currentTarget and currentRemote and currentConfig then
        local now = tick()
        if now - lastAttackTime >= currentConfig.delay then
            local head = currentTarget:FindFirstChild("Head") or currentTarget:FindFirstChild("HumanoidRootPart")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if head and hrp then
                local dir = (head.Position - hrp.Position).Unit
                pcall(function() currentRemote:FireServer("Swing", currentConfig.swing); currentRemote:FireServer("HitZombie", currentTarget, head.Position, true, dir * 15, "Head", dir) end)
                lastAttackTime = now
            end
        end
    end
    for weaponType, config in pairs(ELBOW_CONFIGS) do if activeStates["肘击_" .. weaponType] then local target = findElbowTarget(config.range); if target then lastElbowTimes[weaponType] = attackElbow(target, weaponType, lastElbowTimes[weaponType] or 0, config.delay) end end end
