                                    pcall(function()
                                        remote:FireServer("BraceBlock")
                                        wait(0.05)
                                        remote:FireServer("StopBraceBlock")
                                        remote:FireServer("FeedbackStun", z, z.HumanoidRootPart.CFrame.Position)
                                    end)
                                end
                            end
                        end
                    end
                end
            end
        end
        if CFG.CARBINE_STUN then
            local weapon = char:FindFirstChild("Carbine") or LocalPlayer.Backpack:FindFirstChild("Carbine")
            if weapon then
                if weapon.Parent ~= char then weapon.Parent = char; wait(0.2) end
                local remote = weapon:FindFirstChild("RemoteEvent")
                if remote then
                    local zombies = Workspace:FindFirstChild("Zombies")
                    if zombies then
                        local inRange = {}
                        for _, z in ipairs(zombies:GetChildren()) do
                            if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                                local dist = (char.HumanoidRootPart.Position - z.HumanoidRootPart.Position).Magnitude
                                if dist <= 15 then table.insert(inRange, z) end
                            end
                        end
                        table.sort(inRange, function(a,b) return (a.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude < (b.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude end)
                        local maxTargets = math.min(CFG.STUN_TARGETS, #inRange)
                        if maxTargets > 0 then
                            if inRange[1] then
                                char.HumanoidRootPart.CFrame = CFrame.new(char.HumanoidRootPart.Position, Vector3.new(inRange[1].HumanoidRootPart.Position.X, char.HumanoidRootPart.Position.Y, inRange[1].HumanoidRootPart.Position.Z))
                            end
                            pcall(function() remote:FireServer("Shove") end)
                            wait(0.2)
                            for i = 1, maxTargets do
                                pcall(function() remote:FireServer("FeedbackStun", inRange[i], inRange[i].HumanoidRootPart.CFrame.Position) end)
                                if i < maxTargets then wait(0.1) end
                            end
                        end
                    end
                end
            end
        end
    end
end)

-- ========== 自动射击（枪械） ==========
local function isGun(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local animFolder = tool:FindFirstChild("Animations")
    return animFolder and (animFolder:FindFirstChild("Aim") or animFolder:FindFirstChild("Aiming"))
end

local function getShotsLoaded(tool)
    if not tool then return 0 end
    local s = tool:FindFirstChild("ShotsLoaded")
    if s and (s:IsA("IntValue") or s:IsA("NumberValue")) then return s.Value end
    return 0
end

local function findRemote(tool)
    if not tool then return nil end
    return tool:FindFirstChild("RemoteEvent")
end

local function getNearestTargetByType(matcher)
    local origin = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position or Camera.CFrame.Position
    if not origin then return nil, nil
    local bestPart, bestDist = nil, CFG.AUTO_SHOOT_MAX_RANGE + 1
    local zombies = Workspace:FindFirstChild("Zombies")
    if not zombies then return nil, nil
    for _, model in ipairs(zombies:GetChildren()) do
        if model:IsA("Model") and matcher(model) then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local aimPart = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
                if aimPart then
                    local d = (aimPart.Position - origin).Magnitude
                    if d <= CFG.AUTO_SHOOT_MAX_RANGE and d < bestDist then
                        if CFG.AUTO_SHOOT_WALL_CHECK then
                            local params = RaycastParams.new()
                            params.FilterDescendantsInstances = {LocalPlayer.Character, model}
                            params.FilterType = Enum.RaycastFilterType.Blacklist
                            local res = Workspace:Raycast(origin, (aimPart.Position - origin), params)
                            if not res then bestPart, bestDist = aimPart, d end
                        else
                            bestPart, bestDist = aimPart, d
                        end
                    end
                end
            end
        end
    end
    return bestPart, bestDist
end

spawn(function()
    while true do
        wait(0.1)
        local anyEnabled = CFG.AUTO_SHOOT_BOMBER or CFG.AUTO_SHOOT_CAVALRY or CFG.AUTO_SHOOT_RUNNER or CFG.AUTO_SHOOT_ELECTROCUTIONER or CFG.AUTO_SHOOT_IGNITER
        if not anyEnabled then continue end
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if not tool or not isGun(tool) then continue end
        if getShotsLoaded(tool) == 0 then continue end
        local matchers = {
            [CFG.AUTO_SHOOT_BOMBER] = function(m) return m:FindFirstChild("Barrel") ~= nil end,
            [CFG.AUTO_SHOOT_CAVALRY] = function(m) return m:FindFirstChild("Sword") ~= nil end,
            [CFG.AUTO_SHOOT_RUNNER] = function(m) return m:FindFirstChild("Eye") and not m:FindFirstChild("Axe") end,
            [CFG.AUTO_SHOOT_ELECTROCUTIONER] = function(m) return m:FindFirstChild("Axe") ~= nil end,
            [CFG.AUTO_SHOOT_IGNITER] = function(m) return m:FindFirstChild("Whale Oil Lantern") ~= nil end,
        }
        local bestPart = nil
        for enabled, matcher in pairs(matchers) do
            if enabled then
                local p, _ = getNearestTargetByType(matcher)
                if p then bestPart = p end
            end
        end
        if bestPart then
            local remote = findRemote(tool)
            if remote then
                pcall(function() remote:FireServer("Fire", LocalPlayer.Character:FindFirstChild("Model") or LocalPlayer.Character, bestPart.Position, Workspace:GetServerTimeNow()) end)
            end
        end
    end
end)

