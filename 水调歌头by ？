local function getTracerStartPos()
    local cam = Camera
    local vp = cam.ViewportSize
    if TracerPosition == "屏幕顶部" then return Vector2.new(vp.X / 2, 0)
    elseif TracerPosition == "屏幕底部" then return Vector2.new(vp.X / 2, vp.Y)
    else
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local screenPos = cam:WorldToViewportPoint(hrp.Position)
            return Vector2.new(screenPos.X, screenPos.Y)
        end
        return Vector2.new(vp.X / 2, vp.Y / 2)
    end
end

local function updateVisuals()
    local char = LocalPlayer and LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local cam = Camera
    if not (char and hrp and cam) then
        if fovCircle then fovCircle.Visible = false end
        return
    end
    for _, t in pairs(tracers) do if t then t.Visible = false end end
    if TracerOn and KillAuraEnabled then
        local startPos = getTracerStartPos()
        local targets = getTargetsInRange(KillAuraRange, hrp.Position, FOVEnabled)
        local maxTargets = math.min(#targets, math.max(1, math.floor(MultiTarget)))
        for i = 1, maxTargets do
            local entry = targets[i]
            local partPos = entry.partPos or (entry.part and entry.part.Position)
            if partPos then
                local screenPos, onScreen = cam:WorldToViewportPoint(partPos)
                if onScreen then
                    local line = tracers[i]
                    if not line and Drawing and Drawing.new then
                        line = Drawing.new("Line")
                        line.Color = Color3.fromRGB(255, 0, 0)
                        line.Thickness = 1
                        line.Visible = false
                        tracers[i] = line
                    end
                    if line then
                        line.From = startPos
                        line.To = Vector2.new(screenPos.X, screenPos.Y)
                        line.Visible = true
                    end
                end
            end
        end
    end
    if FOVVisible and fovCircle then
        local size = cam.ViewportSize
        local center = size / 2
        fovCircle.Position = center
        local fovRad = math.rad(FOVSize)
        local camFovRad = math.rad(cam.FieldOfView)
        local radius = (math.tan(fovRad / 2) / math.tan(camFovRad / 2)) * (size.Y / 2)
        fovCircle.Radius = radius
        fovCircle.Visible = true
    elseif fovCircle then
        fovCircle.Visible = false
    end
end

local function manageRenderLoop()
    if (TracerOn or FOVVisible) and not renderConn then
        renderConn = RunService.RenderStepped:Connect(updateVisuals)
    elseif not (TracerOn or FOVVisible) and renderConn then
        renderConn:Disconnect()
        renderConn = nil
        for _, t in pairs(tracers) do if t then t.Visible = false end end
        if fovCircle then fovCircle.Visible = false end
    end
end

