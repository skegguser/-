-- 静默瞄准 hook
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if CFG.JUMP_ON and method == "FireServer" and tostring(self) == "RemoteEvent" then
        if args[1] == "Swing" or args[1] == "Thrust" then
            task.defer(function()
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum and hum.FloorMaterial ~= Enum.Material.Air then hum.Jump = true end
            end)
        end
    end
    if CFG.SILENT_AIM and method == "Raycast" and (self == Workspace or self.ClassName == "Workspace") then
        if not checkcaller() and silentAimCurrentTarget then
            local origin = args[1]
            local aimPos = silentAimCurrentTarget.Position
            local dir = (aimPos - origin)
            args[2] = dir.Unit * (dir.Magnitude + 10)
            return oldNamecall(self, unpack(args))
        end
    end
    return oldNamecall(self, ...)
end)

local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, index)
    if CFG.SILENT_AIM and self == LocalPlayer:GetMouse() and (index == "Hit" or index == "Target") then
        if not checkcaller() and silentAimCurrentTarget then
            return index == "Hit" and silentAimCurrentTarget.CFrame or silentAimCurrentTarget
        end
    end
    return oldIndex(self, index)
end)

