local function setupMenuBtn(name, targetPanel, otherPanels)
    local btn = Instance.new("TextButton", list); btn.Size = UDim2.new(0.95, 0, 0, 26); btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55); btn.Text = name .. " ▷"; btn.TextColor3 = Color3.new(1,1,1); btn.Font = "SourceSansBold"; btn.TextSize = 13
    Instance.new("UICorner", btn); btn.MouseButton1Click:Connect(function()
        if not targetPanel.Visible then
            local lastVisible = nil; for _, panel in ipairs(otherPanels) do if panel.Visible then lastVisible = panel end end
            targetPanel.Position = getSmartPosition(lastVisible, master); targetPanel.Visible = true; btn.Text = name .. " ▽"
        else
            targetPanel.Visible = false; btn.Text = name .. " ▷"
        end
    end)
end

