local function addNewButton(name, callback)
    local btn = Instance.new("TextButton", list)
    btn.Size = UDim2.new(0.95, 0, 0, 26)
    btn.BackgroundColor3 = Color3.fromRGB(35,35,45)
    btn.Text = name .. " [关]"
    btn.TextColor3 = Color3.new(0.8,0.8,0.8)
    btn.Font = "SourceSansBold"
    btn.TextSize = 12
    Instance.new("UICorner", btn)
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name .. (state and " [开]" or " [关]")
        btn.BackgroundColor3 = state and Color3.fromRGB(50,130,80) or Color3.fromRGB(35,35,45)
        callback(state)
    end)
    return btn
end

