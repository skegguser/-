    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool and tool:IsA("Tool") then
            local remote = tool:FindFirstChild("RemoteEvent")
            if remote then remotes[remote] = true end
        end
    end
    lastRemoteScan = tick()
end

