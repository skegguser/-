    espHighlights[model] = {hl = hl, gui = bgui}
end

RunService.Heartbeat:Connect(function()
    local anyNear, currentTargets = false, {}
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    for _, obj in ipairs(Camera:GetChildren()) do
        for name, config in pairs(ESP_CONFIGS) do
            if activeStates[name] and config.check(obj) then
                currentTargets[obj] = true
                createESP(obj, config.color, name)
                if config.alert and activeStates["自爆提醒"] and root then
                    local t = obj:FindFirstChild("Torso") or obj:FindFirstChild("HumanoidRootPart")
                    if t and (root.Position - t.Position).Magnitude <= ALERT_RANGE then anyNear = true end
                end
                break
            end
        end
    end
    
    for m, d in pairs(espHighlights) do 
        if not currentTargets[m] or not m:IsDescendantOf(workspace) then 
            if d.hl then d.hl:Destroy() end
            if d.gui then d.gui:Destroy() end
            espHighlights[m] = nil
            persistentBurners[m] = nil
        end 
    end

    if not CFG.AUTO_FACE_ON then currentTarget = nil return end
    scanTarget()
    if currentTarget then
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local tPart = currentTarget:FindFirstChild("Head") or currentTarget:FindFirstChild("HumanoidRootPart")
        if hrp and tPart then
            if not CFG.FACE_BOMBER then
                local zones = getDangerZones()
                for _, bPos in ipairs(zones) do if (tPart.Position - bPos).Magnitude < 6 then return end end
            end
            local baseLookAt = CFrame.new(hrp.Position, Vector3.new(tPart.Position.X, hrp.Position.Y, tPart.Position.Z))
            hrp.CFrame = baseLookAt * CFrame.Angles(0, math.rad(CFG.LEFT_OFFSET), 0)
        end
    end
end)

