local function createZombieESP(model, espType)
    if espHighlights[model] then return end
    local config = {
        Bomber = {color = Color3.fromRGB(255,180,60), label = "自爆僵尸"},
        Cuirassier = {color = Color3.fromRGB(0,200,255), label = "胸甲骑兵"},
        Runner = {color = Color3.fromRGB(255,0,0), label = "红眼"},
        Zapper = {color = Color3.fromRGB(0,255,0), label = "斧头"},
        Igniter = {color = Color3.fromRGB(255,255,0), label = "提灯人"},
    }
    local cfg = config[espType]
    if not cfg then return end
    local hl = Instance.new("Highlight")
    hl.Adornee = model
    hl.FillColor = cfg.color
    hl.FillTransparency = CFG.ESP_CHAMS_TRANSPARENCY
    hl.OutlineColor = Color3.new(1,1,1)
    hl.OutlineTransparency = 0
    hl.Parent = model
    local billboard = nil
    if CFG.ESP_SHOW_BILLBOARDS then
        local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
        if torso then
            billboard = Instance.new("BillboardGui")
            billboard.Adornee = torso
            billboard.Size = UDim2.new(0, 100, 0, 40)
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            billboard.AlwaysOnTop = true
            local label = Instance.new("TextLabel", billboard)
            label.Size = UDim2.new(1,0,1,0)
            label.BackgroundTransparency = 1
            label.Text = cfg.label
            label.TextColor3 = cfg.color
            label.TextScaled = true
            label.Font = Enum.Font.GothamBold
            billboard.Parent = model
        end
    end
    espHighlights[model] = {hl = hl, bb = billboard}
end

local function updateZombieESP()
    local camFolder = Workspace:FindFirstChild("Camera")
    if not camFolder then return end
    local enabledTypes = {}
    if CFG.ESP_BOMBER then enabledTypes.Bomber = true end
    if CFG.ESP_CUIRASSIER then enabledTypes.Cuirassier = true end
    if CFG.ESP_RUNNER then enabledTypes.Runner = true end
    if CFG.ESP_ZAPPER then enabledTypes.Zapper = true end
    if CFG.ESP_IGNITER then enabledTypes.Igniter = true end
    local seen = {}
    for _, obj in ipairs(camFolder:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "m_Zombie" then
            local espType = nil
            if enabledTypes.Bomber and obj:FindFirstChild("Barrel") then espType = "Bomber"
            elseif enabledTypes.Cuirassier and obj:FindFirstChild("Sword") then espType = "Cuirassier"
            elseif enabledTypes.Runner and obj:FindFirstChild("Eye") and not obj:FindFirstChild("Axe") then espType = "Runner"
            elseif enabledTypes.Zapper and obj:FindFirstChild("Axe") then espType = "Zapper"
            elseif enabledTypes.Igniter and obj:FindFirstChild("Whale Oil Lantern") then espType = "Igniter" end
            if espType then
                seen[obj] = true
                if not espHighlights[obj] then createZombieESP(obj, espType) end
            end
        end
    end
    for model, data in pairs(espHighlights) do
        if not seen[model] then
            if data.hl then data.hl:Destroy() end
            if data.bb then data.bb:Destroy() end
            espHighlights[model] = nil
        end
    end
end
task.spawn(function()
    while true do
        updateZombieESP()
        task.wait(0.25)
    end
end)

