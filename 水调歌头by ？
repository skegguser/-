-- 自救
local selfRescueConn = nil
local function setupSelfRescue()
    if CFG.SELF_RESCUE then
        if not selfRescueConn then
            selfRescueConn = RunService.Heartbeat:Connect(function()
                local char = LocalPlayer.Character
                if not char then return end
                local weapon = nil
                for _, child in pairs(char:GetChildren()) do
                    if child:GetAttribute("Melee") then weapon = child; break end
                end
                if not weapon then
                    for _, child in pairs(LocalPlayer.Backpack:GetChildren()) do
                        if child:GetAttribute("Melee") then weapon = child; break end
                    end
                end
                if weapon then
                    local zombies = Workspace:FindFirstChild("Zombies")
                    if zombies then
                        for _, z in ipairs(zombies:GetChildren()) do
                            if z:IsA("Model") and z:FindFirstChild("HumanoidRootPart") then
                                local dist = (char.HumanoidRootPart.Position - z.HumanoidRootPart.Position).Magnitude
                                if dist <= 5 then
                                    if weapon.Parent ~= char then weapon.Parent = char; wait(0.1) end
                                    char.HumanoidRootPart.CFrame = CFrame.lookAt(char.HumanoidRootPart.Position, Vector3.new(z.HumanoidRootPart.Position.X, char.HumanoidRootPart.Position.Y, z.HumanoidRootPart.Position.Z))
                                    local remote = char:FindFirstChild(weapon.Name) and char[weapon.Name]:FindFirstChild("RemoteEvent")
                                    if remote then
                                        pcall(function() remote:FireServer("Swing", "Side") end)
                                        local head = z:FindFirstChild("Head")
                                        if head then pcall(function() remote:FireServer("HitZombie", z, head.Position, true) end) end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    else
        if selfRescueConn then selfRescueConn:Disconnect(); selfRescueConn = nil end
    end
end

-- 自动跳跃（刺击时跳跃）
local autoJumpAnimator = nil
local autoJumpMonitoring = false
local autoJumpPlayedTracks = {}
local TARGET_ANIM_IDS = {
    "rbxassetid://17406577733",
    "rbxassetid://15669224658",
    "rbxassetid://12591948314",
    "rbxassetid://12333491302",
}
local function normalizeAnimId(id)
    local s = tostring(id)
    if s:match("^%d+$") then return "rbxassetid://" .. s end
    return s
end
local TARGETS = {}
for _, v in ipairs(TARGET_ANIM_IDS) do TARGETS[normalizeAnimId(v)] = true end
local function trackIsTarget(track)
    if not track or not track.IsPlaying then return false end
    local anim = track.Animation
    if not anim or not anim.AnimationId then return false end
    return TARGETS[normalizeAnimId(anim.AnimationId)]
end
local function doAutoJump()
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    spawn(function()
        local root = hum.RootPart or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart"))
        if root then
            root.Velocity = Vector3.new(root.Velocity.X, 30, root.Velocity.Z)
        end
    end)
end
local function startAutoJumpMonitoring()
    if autoJumpMonitoring then return end
    autoJumpMonitoring = true
    spawn(function()
        while autoJumpMonitoring do
            if autoJumpAnimator then
                local ok, tracks = pcall(function() return autoJumpAnimator:GetPlayingAnimationTracks() end)
                if ok and tracks then
                    for _, track in ipairs(tracks) do
                        if trackIsTarget(track) and not autoJumpPlayedTracks[track] then
                            autoJumpPlayedTracks[track] = true
                            pcall(doAutoJump)
                            track.Stopped:Connect(function() autoJumpPlayedTracks[track] = nil end)
                        end
                    end
                end
            end
            wait(0.08)
        end
    end)
end
local function stopAutoJumpMonitoring()
    autoJumpMonitoring = false
    autoJumpPlayedTracks = {}
end
local function refreshAutoJumpAnimator()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            autoJumpAnimator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
        end
    end
end
refreshAutoJumpAnimator()
LocalPlayer.CharacterAdded:Connect(function() wait(0.5); refreshAutoJumpAnimator() end)

