    title.BackgroundTransparency = 1
    title.Text = "丝滑飞行"
    title.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    title.TextSize = 12

    local speedInput = Instance.new("TextBox", flyMainFrame)
    speedInput.Size = UDim2.new(0, 140, 0, 30)
    speedInput.Position = UDim2.new(0.5, -70, 0, 40)
    speedInput.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    speedInput.Text = "35"
    speedInput.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", speedInput).CornerRadius = UDim.new(0, 8)

    local toggleBtn = Instance.new("TextButton", flyMainFrame)
    toggleBtn.Size = UDim2.new(0, 140, 0, 40)
    toggleBtn.Position = UDim2.new(0.5, -70, 0, 85)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    toggleBtn.Text = "丝滑飞行: OFF"
    toggleBtn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 10)

    -- 飞行核心变量
    local isFlying = false
    local flySpeed = 35
    local flyBodyVelocity = nil
    local flyBodyGyro = nil
    local flyAnimCache = nil
    local flyControlModule = nil

    local function getControlModule()
        if flyControlModule then return flyControlModule end
        local success, module = pcall(function()
            return require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule")):GetControls()
        end)
        if success then flyControlModule = module; return module end
        return nil
    end

    local function startFly()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local animate = char:FindFirstChild("Animate")
        if animate then flyAnimCache = animate; animate.Parent = nil end
        flyBodyVelocity = Instance.new("BodyVelocity", hrp)
        flyBodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        flyBodyGyro = Instance.new("BodyGyro", hrp)
        flyBodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        flyBodyGyro.P = 8000
        task.spawn(function()
            local ctrl = getControlModule()
            while isFlying and char and char.Parent do
                if ctrl then
                    local moveVec = ctrl:GetMoveVector()
                    local camCF = Camera.CFrame
                    local moveDir = (camCF.LookVector * -moveVec.Z) + (camCF.RightVector * moveVec.X)
                    if moveVec.Magnitude > 0 then
                        flyBodyVelocity.Velocity = moveDir.Unit * flySpeed
                        flyBodyGyro.CFrame = CFrame.new(Vector3.zero, moveDir)
                    else
                        flyBodyVelocity.Velocity = Vector3.new(0, 0.01, 0)
                        flyBodyGyro.CFrame = CFrame.new(Vector3.zero, Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z))
                    end
                    hum:ChangeState(Enum.HumanoidStateType.Climbing)
                end
                RunService.RenderStepped:Wait()
            end
            if flyAnimCache then flyAnimCache.Parent = char end
            if flyBodyVelocity then flyBodyVelocity:Destroy() end
            if flyBodyGyro then flyBodyGyro:Destroy() end
        end)
    end

    local function stopFly()
        isFlying = false
        if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
        if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
        if flyAnimCache and LocalPlayer.Character then
            flyAnimCache.Parent = LocalPlayer.Character
            flyAnimCache = nil
        end
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum and hum:GetState() == Enum.HumanoidStateType.Climbing then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end

    toggleBtn.MouseButton1Click:Connect(function()
        isFlying = not isFlying
        flySpeed = tonumber(speedInput.Text) or 35
        toggleBtn.Text = isFlying and "已开启 - 运行中" or "丝滑飞行: OFF"
        TweenService:Create(toggleBtn, TweenInfo.new(0.3), {BackgroundColor3 = isFlying and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(60, 60, 60)}):Play()
        if isFlying then
            startFly()
        else
            stopFly()
        end
    end)

    -- 拖动逻辑
    local dragging, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        flyMainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    flyMainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = flyMainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    flyMainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)

    -- 关闭和最小化按钮
    local function topBtn(t, x, c, f)
        local b = Instance.new("TextButton", flyMainFrame)
        b.Size = UDim2.new(0, 25, 0, 25)
        b.Position = UDim2.new(1, x, 0, 5)
        b.Text = t
        b.BackgroundColor3 = c
        b.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        b.MouseButton1Click:Connect(f)
    end
    topBtn("×", -30, Color3.fromRGB(150,50,50), function() isFlying = false; flyScreenGui:Destroy() end)
    topBtn("-", -60, Color3.fromRGB(70,70,70), function()
        local collapsed = flyMainFrame.Size.Y.Offset < 140
        local targetH = collapsed and 140 or 35
        TweenService:Create(flyMainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 180, 0, targetH)}):Play()
        toggleBtn.Visible = collapsed
        speedInput.Visible = collapsed
    end)

    -- 进场动画
    flyMainFrame.Size = UDim2.new(0, 0, 0, 0)
    flyMainFrame:TweenSize(UDim2.new(0, 180, 0, 140), "Out", "Back", 0.5)

    -- 摔伤拦截（飞行专用）
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" and tostring(self) == "ForceSelfDamage" then
            return nil
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end

