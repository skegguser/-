-- ========== 辅助函数 ==========
local function isGun(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local animFolder = tool:FindFirstChild("Animations")
    return animFolder and (animFolder:FindFirstChild("Aim") or animFolder:FindFirstChild("Aiming"))
end
local function getShotsLoaded(tool)
    if not tool then return 0 end
    local s = tool:FindFirstChild("ShotsLoaded")
    return s and s.Value or 0
end
local function findRemote(tool)
    return tool and tool:FindFirstChild("RemoteEvent")
end
local function getPredictedPos(part)
    if not part then return nil end
    local pos = part.Position
    if GUN_PREDICTION <= 0 then return pos end
    local vel = part.AssemblyLinearVelocity or Vector3.new(0,0,0)
    return pos + vel * GUN_PREDICTION
end
local function isWorldPosInFov(worldPos)
    if not GUN_USE_FOV then return true end
    local cam = Workspace.CurrentCamera
    if not cam then return true end
    local screenPos, onScreen = cam:WorldToViewportPoint(worldPos)
    if not onScreen then return false end
    local centerVec = (UserInputService:GetMouseLocation() - GuiService:GetGuiInset())
    local sizePx = (math.clamp(GUN_FOV_SIZE, 10, 120) / 40) * 250
    local dist = (Vector2.new(screenPos.X, screenPos.Y) - centerVec).Magnitude
    return dist <= (sizePx / 2)
end

-- 枪械装填
local function performReload(tool, targetShots)
    if reloadInProgress[tool] then return end
    reloadInProgress[tool] = true
    local remote = findRemote(tool)
    if not remote then reloadInProgress[tool]=nil return end
    if targetShots>1 then pcall(function() remote:FireServer("StartReload") end) wait(0.1) end
    for _=1,50 do
        if getShotsLoaded(tool) >= targetShots then
            pcall(function() tool.Parent = LocalPlayer.Backpack end)
            wait(0.02)
            pcall(function() tool.Parent = LocalPlayer.Character end)
            break
        end
        pcall(function() remote:FireServer("Reload") end)
        wait(0.05)
    end
    reloadInProgress[tool]=nil
end
local function tryReload(tool)
    if not GUN_AUTO_RELOAD or not isGun(tool) then return end
    local shots = getShotsLoaded(tool)
    if tool.Name=="Nock Gun" and shots<7 then spawn(function() performReload(tool,7) end)
    elseif (tool.Name=="Double Barrel Pistol" or tool.Name=="Horse Artillery Pistol") and shots==0 then spawn(function() performReload(tool,2) end)
    elseif shots==0 then spawn(function() performReload(tool,1) end) end
end

-- 枪械目标获取
local function getNearestZombieGun(range)
    local cam = Workspace.CurrentCamera
    local origin = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position or cam.CFrame.Position
    if not origin then return nil end
    local bestPart,bestDist = nil,range
    local zombies = Workspace:FindFirstChild("Zombies")
    if not zombies then return nil end
    for _,model in ipairs(zombies:GetDescendants()) do
        if model:IsA("Model") and not model:FindFirstChild("Spawn") then
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then
                local aimPart = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
                if aimPart then
                    local aimPos = getPredictedPos(aimPart)
                    if isWorldPosInFov(aimPos) then
                        local d = (aimPos-origin).Magnitude
                        if d<=bestDist then bestPart=aimPart; bestDist=d end
                    end
                end
            end
        end
    end
    return bestPart
end

