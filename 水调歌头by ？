-- 黑枪模块源代码
local blackGunSource = [[
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local Workspace = game:GetService("Workspace")
    local lp = Players.LocalPlayer
    local ENABLED = false
    local SMOOTH_TIME = 0.28
    local COOLDOWN = 0.1
    local EQUIP_DELAY = 0.2
    local BARREL_DIST_CHECK = 14
    local WALL_CHECK = true
    local MAX_RANGE = 200
    local function isGun(tool)
        if not tool or not tool:IsA("Tool") then return false end
        local animFolder = tool:FindFirstChild("Animations")
        if not animFolder then return false end
        return animFolder:FindFirstChild("Aim") ~= nil or animFolder:FindFirstChild("Aiming") ~= nil
    end
    local function getShotsLoaded(tool)
        if not tool then return 0 end
        local shots = tool:FindFirstChild("ShotsLoaded")
        if shots and (shots:IsA("IntValue") or shots:IsA("NumberValue")) then return shots.Value end
        local wsFolder = Workspace:FindFirstChild("Players")
        if wsFolder then
            local playerFolder = wsFolder:FindFirstChild(lp.Name)
            if playerFolder then
                local toolFolder = playerFolder:FindFirstChild(tool.Name)
                if toolFolder then
                    local s = toolFolder:FindFirstChild("ShotsLoaded")
                    if s then return s.Value end
                end
            end
        end
        return 0
    end
    local function getRemote(tool)
        if not tool then return nil end
        local remote = tool:FindFirstChild("RemoteEvent")
        if remote then return remote end
        local wsFolder = Workspace:FindFirstChild("Players")
        if wsFolder then
            local playerFolder = wsFolder:FindFirstChild(lp.Name)
            if playerFolder then
                local toolFolder = playerFolder:FindFirstChild(tool.Name)
                if toolFolder then return toolFolder:FindFirstChild("RemoteEvent") end
            end
        end
        return nil
    end
    local function isObstructed(origin, targetPos, targetModel)
        if not WALL_CHECK then return false end
        if not origin or not targetPos then return false end
        local dir = targetPos - origin
        local dist = dir.Magnitude
        if dist <= 0 then return false end
        local function buildIgnoreList()
            local ignore = {}
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl.Character then table.insert(ignore, pl.Character) end
            end
            local zombies = Workspace:FindFirstChild("Zombies")
            if zombies then table.insert(ignore, zombies) end
            local camFolder = Workspace:FindFirstChild("Camera")
            if camFolder then
                for _, obj in ipairs(camFolder:GetChildren()) do
                    if obj:IsA("Model") and obj.Name == "m_Zombie" then table.insert(ignore, obj) end
                end
            end
            if targetModel then table.insert(ignore, targetModel) end
            return ignore
        end
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Blacklist
        params.FilterDescendantsInstances = buildIgnoreList()
        local rayOrigin = origin
        local remaining = dist
        local dirUnit = dir.Unit
        local epsilon = 0.2
        for _ = 1, 12 do
            local result = workspace:Raycast(rayOrigin, dirUnit * remaining, params)
            if not result then return false end
            local hit = result.Instance
            if targetModel and hit:IsDescendantOf(targetModel) then return false end
            local isBasePart = hit:IsA("BasePart")
            local canCollide = isBasePart and hit.CanCollide
            local transparency = isBasePart and hit.Transparency or 0
            local isInvisible = (not canCollide) or (transparency >= 0.95)
            if isInvisible then
                local newOrigin = result.Position + dirUnit * epsilon
                local passed = (newOrigin - origin).Magnitude
                if passed >= dist - 1e-4 then return false end
                rayOrigin = newOrigin
                remaining = (targetPos - rayOrigin).Magnitude
                local newFilter = params.FilterDescendantsInstances
                table.insert(newFilter, hit)
                params.FilterDescendantsInstances = newFilter
            else
                return true
            end
        end
        return false
    end
    local function isBomberModel(model)
        return model:FindFirstChild("Barrel") ~= nil
    end
    local function getNearestBomber()
        local camFolder = Workspace:FindFirstChild("Camera")
        if not camFolder then return nil, nil end
        local origin = nil
        local char = lp.Character
        if char then
            local head = char:FindFirstChild("Head")
            if head and head:IsA("BasePart") then origin = head.Position end
        end
        if not origin then
            local cam = workspace.CurrentCamera
            if cam then origin = cam.CFrame.Position end
        end
        if not origin then return nil, nil end
        local bestPart, bestModel, bestDist = nil, nil, MAX_RANGE + 1
        for _, model in ipairs(camFolder:GetChildren()) do
            if model:IsA("Model") and model.Name == "m_Zombie" and isBomberModel(model) then
                local barrel = model:FindFirstChild("Barrel")
                local head = model:FindFirstChild("Head")
                local torso = model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("HumanoidRootPart")
                local measurePart = barrel or head or torso
                if measurePart and measurePart:IsA("BasePart") then
                    local dist = (measurePart.Position - origin).Magnitude
                    if dist <= MAX_RANGE and dist < bestDist then
                        local chosen = nil
                        if barrel and not isObstructed(origin, barrel.Position, model) then chosen = barrel
                        elseif head and not isObstructed(origin, head.Position, model) then chosen = head
                        elseif torso and not isObstructed(origin, torso.Position, model) then chosen = torso end
                        if chosen then
                            bestPart, bestModel, bestDist = chosen, model, dist
                        end
                    end
                end
            end
        end
        return bestPart, bestModel
    end
    local function smoothLookAt(rootPart, getPosFunc, duration)
        if not rootPart or not getPosFunc then return end
        local startTime = tick()
        local startCF = rootPart.CFrame
        local ok, initTarget = pcall(getPosFunc)
        if not ok or not initTarget then return end
        while tick() - startTime < duration do
            if not rootPart.Parent then return end
            local curPos = nil
            pcall(function() curPos = getPosFunc() end)
            if not curPos then curPos = initTarget end
            local desired = CFrame.new(rootPart.Position, Vector3.new(curPos.X, rootPart.Position.Y, curPos.Z))
            local t = math.clamp((tick() - startTime) / duration, 0, 1)
            local smooth = t * t * (3 - 2 * t)
            local lerped = startCF:Lerp(desired, smooth)
            rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + lerped.LookVector)
            RunService.RenderStepped:Wait()
        end
        local finalPos = nil
        pcall(function() finalPos = getPosFunc() end)
        if finalPos then
            rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position + CFrame.new(rootPart.Position, Vector3.new(finalPos.X, rootPart.Position.Y, finalPos.Z)).LookVector)
        end
    end
    local function aimAndShoot(targetModel, initialPart, tool)
        if not targetModel or not targetModel.Parent then return end
        if not initialPart or not initialPart.Parent then return end
        if not tool or not tool.Parent or not tool:IsDescendantOf(lp.Character) then return end
        local char = lp.Character
        if not char then return end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if not animator then
            animator = Instance.new("Animator")
            animator.Parent = humanoid
        end
        local animFolder = tool:FindFirstChild("Animations")
        local aimAnimId, aimingAnimId, fireAnimId = nil, nil, nil
        if animFolder then
            local aim = animFolder:FindFirstChild("Aim")
            local aiming = animFolder:FindFirstChild("Aiming")
            local fire = animFolder:FindFirstChild("Fire")
            if aim and aim:IsA("Animation") then aimAnimId = aim.AnimationId end
            if aiming and aiming:IsA("Animation") then aimingAnimId = aiming.AnimationId end
            if fire and fire:IsA("Animation") then fireAnimId = fire.AnimationId end
        end
        aimAnimId = aimAnimId or "rbxassetid://83511222574103"
        aimingAnimId = aimingAnimId or "rbxassetid://136849639865723"
        local trackA = nil
        if aimAnimId then
            local anim = Instance.new("Animation")
            anim.AnimationId = aimAnimId
            trackA = animator:LoadAnimation(anim)
            trackA:Play(0.05, 1, 1)
            task.wait(math.min(trackA.Length or 0.6, 0.6))
            trackA:Stop(0.05)
        end
        local trackB = nil
        if aimingAnimId then
            local anim = Instance.new("Animation")
            anim.AnimationId = aimingAnimId
            trackB = animator:LoadAnimation(anim)
            trackB:Play(0.05, 1, 1)
        end
        task.wait(0.02)
        local function getOrigin()
            local head = char:FindFirstChild("Head")
            if head and head:IsA("BasePart") then return head.Position end
            return workspace.CurrentCamera.CFrame.Position
        end
        local currentTarget = initialPart
        local function getTargetPos()
            if not currentTarget or not currentTarget.Parent then
                local barrel = targetModel:FindFirstChild("Barrel")
                local head = targetModel:FindFirstChild("Head")
                local torso = targetModel:FindFirstChild("Torso") or targetModel:FindFirstChild("UpperTorso") or targetModel:FindFirstChild("HumanoidRootPart")
                local origin = getOrigin()
                if barrel and not isObstructed(origin, barrel.Position, targetModel) then currentTarget = barrel
                elseif head and not isObstructed(origin, head.Position, targetModel) then currentTarget = head
                elseif torso and not isObstructed(origin, torso.Position, targetModel) then currentTarget = torso
                else return nil end
            end
            return currentTarget.Position
        end
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if rootPart then
            pcall(function() smoothLookAt(rootPart, getTargetPos, SMOOTH_TIME) end)
        end
        local waited = 0
        while getShotsLoaded(tool) < 1 and waited < 3.0 do
            if not tool.Parent or not ENABLED then
                if trackB then trackB:Stop(0.1) end
                return
            end
            task.wait(0.05)
            waited = waited + 0.05
        end
        if getShotsLoaded(tool) < 1 then
            if trackB then trackB:Stop(0.1) end
            return
        end
        task.wait(0.03)
        local finalTarget = nil
        local origin = getOrigin()
        local barrel = targetModel:FindFirstChild("Barrel")
        local head = targetModel:FindFirstChild("Head")
        local torso = targetModel:FindFirstChild("Torso") or targetModel:FindFirstChild("UpperTorso") or targetModel:FindFirstChild("HumanoidRootPart")
        if barrel and not isObstructed(origin, barrel.Position, targetModel) then finalTarget = barrel
        elseif head and not isObstructed(origin, head.Position, targetModel) then finalTarget = head
        elseif torso and not isObstructed(origin, torso.Position, targetModel) then finalTarget = torso
        else
            if trackB then trackB:Stop(0.1) end
            return
        end
        local fireTrack = nil
        if fireAnimId then
            local anim = Instance.new("Animation")
            anim.AnimationId = fireAnimId
            fireTrack = animator:LoadAnimation(anim)
            fireTrack:Play(0.05, 1, 1)
        end
        local remote = getRemote(tool)
        if remote and finalTarget then
            local modelRef = char:FindFirstChild("Model") or char
            remote:FireServer("Fire", modelRef, finalTarget.Position, workspace:GetServerTimeNow())
        end
        if fireTrack then
            task.delay(0.35, function() pcall(function() fireTrack:Stop(0.07) end) end)
        end
        if trackB then
            task.wait(0.05)
            trackB:Stop(0.1)
        end
    end
    local function hasOtherPlayerNear(zombie, barrelDist)
        if not zombie or not zombie:FindFirstChild("HumanoidRootPart") then return false end
        local zPos = zombie.HumanoidRootPart.Position
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= lp and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
                local pPos = pl.Character.HumanoidRootPart.Position
                if (pPos - zPos).Magnitude <= barrelDist then return true end
            end
        end
        return false
    end
    local function onTick()
        if not ENABLED then return end
        local tool = lp.Character and lp.Character:FindFirstChildOfClass("Tool")
        if not tool or not isGun(tool) then return end
        if getShotsLoaded(tool) < 1 then return end
        local targetPart, targetModel = getNearestBomber()
        if not targetPart or not targetModel then return end
        if not hasOtherPlayerNear(targetModel, BARREL_DIST_CHECK) then return end
        if EQUIP_DELAY > 0 then task.wait(EQUIP_DELAY) end
        if not tool.Parent or getShotsLoaded(tool) < 1 then return end
        aimAndShoot(targetModel, targetPart, tool)
    end
    local loopRunning = false
    local loopThread = nil
    local function startLoop()
        if loopThread then return end
        loopRunning = true
        loopThread = task.spawn(function()
            while loopRunning do
                onTick()
                task.wait(COOLDOWN)
            end
        end)
    end
    local function stopLoop()
        loopRunning = false
        if loopThread then
            task.cancel(loopThread)
            loopThread = nil
        end
    end
    return {
        enable = function() ENABLED = true; startLoop() end,
        disable = function() ENABLED = false; stopLoop() end,
    }
]]

