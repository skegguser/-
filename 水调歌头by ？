-- 音乐环绕
local function createMusicDiamonds()
    if musicConn then musicConn:Disconnect() end
    for _, d in pairs(musicDiamonds) do if d and d.Parent then d:Destroy() end end
    table.clear(musicDiamonds)
    if not CFG.MUSIC_DIAMONDS then return end
    local AMOUNT = 40
    local BASE_DISTANCE = 7
    local HEIGHT = 1
    local SIZE = Vector3.new(0.3,0.3,0.3)
    for i = 1, AMOUNT do
        local part = Instance.new("Part")
        part.Size = SIZE
        part.Anchored = true
        part.CanCollide = false
        part.Material = Enum.Material.Neon
        part.Parent = workspace
        musicDiamonds[i] = {part = part, angle = (math.pi * 2 / AMOUNT) * i}
    end
    local colorTime = 0
    musicConn = RunService.RenderStepped:Connect(function(dt)
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        colorTime = colorTime + dt * 0.15
        for _, data in ipairs(musicDiamonds) do
            local x = math.cos(data.angle) * BASE_DISTANCE
            local z = math.sin(data.angle) * BASE_DISTANCE
