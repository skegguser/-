MainTab:Button({
    Title = "Execute Flight",
    Desc = "Run QiuRong Silk Flight",
    Callback = function()
        -- Load flight script directly (from provided "飞行不拉回GB.lua" logic)
        -- To avoid external request, embed simplified version (you may replace with actual url)
        loadstring([[
            -- Simplified flight bypass (original functionality preserved)
            local Players = game:GetService("Players")
            local RunService = game:GetService("RunService")
            local UserInputService = game:GetService("UserInputService")
            local lp = Players.LocalPlayer
            local camera = workspace.CurrentCamera
            local flying = false
            local speed = 35
            local bv, bg

            local function startFly()
                local char = lp.Character or lp.CharacterAdded:Wait()
                local hrp = char:WaitForChild("HumanoidRootPart")
                local hum = char:WaitForChild("Humanoid")
                bv = Instance.new("BodyVelocity", hrp)
                bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
                bg = Instance.new("BodyGyro", hrp)
                bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
                bg.P = 8000
                local ctrl = require(lp.PlayerScripts:WaitForChild("PlayerModule")):GetControls()
                while flying and char.Parent do
                    local moveVec = ctrl:GetMoveVector()
                    local cf = camera.CFrame
                    local dir = (cf.LookVector * -moveVec.Z) + (cf.RightVector * moveVec.X)
                    if moveVec.Magnitude > 0 then
                        bv.Velocity = dir.Unit * speed
                        bg.CFrame = CFrame.new(Vector3.zero, dir)
                    else
                        bv.Velocity = Vector3.new(0,0.01,0)
                        bg.CFrame = CFrame.new(Vector3.zero, Vector3.new(cf.LookVector.X,0,cf.LookVector.Z))
                    end
                    hum:ChangeState(Enum.HumanoidStateType.Climbing)
                    RunService.RenderStepped:Wait()
                end
                if bv then bv:Destroy() end
                if bg then bg:Destroy() end
            end

            -- UI toggle (optional)
            local screenGui = Instance.new("ScreenGui", lp:WaitForChild("PlayerGui"))
            screenGui.Name = "QuickFly"
            local frame = Instance.new("Frame", screenGui)
            frame.Size = UDim2.new(0,150,0,80)
            frame.Position = UDim2.new(0.5,-75,0.5,-40)
            frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
            local btn = Instance.new("TextButton", frame)
            btn.Size = UDim2.new(1,0,1,0)
            btn.Text = "Fly: OFF"
            btn.BackgroundColor3 = Color3.fromRGB(80,80,80)
            btn.MouseButton1Click:Connect(function()
                flying = not flying
                btn.Text = flying and "Fly: ON" or "Fly: OFF"
                if flying then startFly() end
            end)
        ]])()
        WindUI:Notify({ Title = "Flight", Content = getText("flight_executed"), Duration = 2 })
    end,
})

