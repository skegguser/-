-- ========== 辅助函数 ==========
local function isGun(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local animFolder = tool:FindFirstChild("Animations")
    return animFolder and (animFolder:FindFirstChild("Aim") or animFolder:FindFirstChild("Aiming"))
end

local function getShotsLoaded(tool)
    if not tool then return 0 end
    local s = tool:FindFirstChild("ShotsLoaded")
    if s and (s:IsA("IntValue") or s:IsA("NumberValue")) then return s.Value end
    local wsPlayers = Workspace:FindFirstChild("Players")
    if wsPlayers then
        local pf = wsPlayers:FindFirstChild(LocalPlayer.Name)
        if pf then
            local tf = pf:FindFirstChild(tool.Name)
            if tf then
                local sh = tf:FindFirstChild("ShotsLoaded")
                if sh then return sh.Value end
            end
        end
    end
    return 0
end

local function findRemote(tool)
    if not tool then return nil end
    local r = tool:FindFirstChild("RemoteEvent")
    if r then return r end
    local wsPlayers = Workspace:FindFirstChild("Players")
    if wsPlayers then
        local pf = wsPlayers:FindFirstChild(LocalPlayer.Name)
        if pf then
            local tf = pf:FindFirstChild(tool.Name)
            if tf then return tf:FindFirstChild("RemoteEvent") end
        end
    end
    return nil
end

-- ========== 飞行模块 ==========
local function getFlyControl()
    if flyCtrl then return flyCtrl end
    local success, module = pcall(function()
        return require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule")):GetControls()
    end)
    if success then flyCtrl = module; return module end
    return nil
end

local function startFly()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    local animate = char:FindFirstChild("Animate")
    if animate then flyAnimCache = animate; animate.Parent = nil end
    flyBodyVelocity = Instance.new("BodyVelocity", hrp)
    flyBodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    flyBodyGyro = Instance.new("BodyGyro", hrp)
    flyBodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    flyBodyGyro.P = 8000
    local flySpeedVal = CFG.FLY_SPEED * 5
    flyConnection = RunService.RenderStepped:Connect(function()
        if not CFG.FLY_ENABLED then return end
        local ctrl = getFlyControl()
        if not ctrl then return end
        local moveVec = ctrl:GetMoveVector()
        local camCF = Camera.CFrame
        local moveDir = (camCF.LookVector * -moveVec.Z) + (camCF.RightVector * moveVec.X)
        if moveVec.Magnitude > 0 then
            flyBodyVelocity.Velocity = moveDir.Unit * flySpeedVal
            flyBodyGyro.CFrame = CFrame.new(Vector3.zero, moveDir)
        else
            flyBodyVelocity.Velocity = Vector3.new(0, 0.01, 0)
            flyBodyGyro.CFrame = CFrame.new(Vector3.zero, Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z))
        end
        hum:ChangeState(Enum.HumanoidStateType.Climbing)
    end)
    local function up() if CFG.FLY_ENABLED then hrp.CFrame = hrp.CFrame * CFrame.new(0, 1, 0) end end
    local function down() if CFG.FLY_ENABLED then hrp.CFrame = hrp.CFrame * CFrame.new(0, -1, 0) end end
    flyUpConn = UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.Space then
            task.spawn(function() while CFG.FLY_ENABLED and UserInputService:IsKeyDown(Enum.KeyCode.Space) do up() task.wait() end end)
        elseif input.KeyCode == Enum.KeyCode.LeftShift then
            task.spawn(function() while CFG.FLY_ENABLED and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) do down() task.wait() end end)
        end
    end)
end

local function stopFly()
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    if flyUpConn then flyUpConn:Disconnect(); flyUpConn = nil end
    if flyDownConn then flyDownConn:Disconnect(); flyDownConn = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    if flyAnimCache and LocalPlayer.Character then flyAnimCache.Parent = LocalPlayer.Character; flyAnimCache = nil end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum and hum:GetState() == Enum.HumanoidStateType.Climbing then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
end

-- 反自伤/反布娃娃 Hook
local function setupAntiDamageHooks()
    if CFG.ANTI_SELF_DAMAGE then
        namecallHook1 = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod():lower()
            if self.Name == "ForceSelfDamage" and method == "fireserver" then return nil end
            return namecallHook1(self, ...)
        end))
    else
        if namecallHook1 then hookmetamethod(game, "__namecall", namecallHook1); namecallHook1 = nil end
    end
    if CFG.ANTI_RAGDOLL then
        namecallHook2 = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            if method == "SetStateEnabled" and self:IsA("Humanoid") and args[1] == Enum.HumanoidStateType.Ragdoll then
                return namecallHook2(self, args[1], false)
            end
            return namecallHook2(self, ...)
        end))
    else
        if namecallHook2 then hookmetamethod(game, "__namecall", namecallHook2); namecallHook2 = nil end
    end
end

