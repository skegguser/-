-- 攻击主循环
task.spawn(function()
    while true do
        if KILLAURA_ON then
            scanTarget()
            autoEquipWeapon()
            local char = LocalPlayer.Character
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool and WEAPON_DB[tool.Name] then
                    currentRemote = tool:FindFirstChild("RemoteEvent")
                    currentConfig = WEAPON_DB[tool.Name]
                end
            end
            if currentTarget and currentRemote and currentConfig then
                local now = tick()
                if now - lastAttackTime >= currentConfig.delay then
                    local head = currentTarget:FindFirstChild("Head") or currentTarget:FindFirstChild("HumanoidRootPart")
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if head and hrp then
                        local dir = (head.Position - hrp.Position).Unit
                        pcall(function()
                            currentRemote:FireServer("Swing", currentConfig.swing)
                            currentRemote:FireServer("HitZombie", currentTarget, head.Position, true, dir * 15, "Head", dir)
                        end)
                        lastAttackTime = now
                    end
                end
            end
            -- 肘击
            for weaponType, config in pairs(ELBOW_CONFIGS) do
                if activeStates["肘击_" .. weaponType] then
                    local target = findElbowTarget(config.range)
                    if target then
                        lastElbowTimes[weaponType] = attackElbow(target, weaponType, lastElbowTimes[weaponType] or 0, config.delay)
                    end
                end
            end
            -- 自动面向
            if AUTO_FACE_ON and currentTarget then
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local tRoot = currentTarget:FindFirstChild("HumanoidRootPart") or currentTarget:FindFirstChild("Torso")
                if hrp and tRoot then
                    hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(tRoot.Position.X, hrp.Position.Y, tRoot.Position.Z))
                end
            end
        end
        task.wait(0.1)
    end
end)
