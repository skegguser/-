local function distSqVec3(a, b)
    local dx, dy, dz = a.X - b.X, a.Y - b.Y, a.Z - b.Z
    return dx*dx + dy*dy + dz*dz
end

local function isBomber(obj)
    if not obj or not obj:IsA("Model") then return false end
    if obj:GetAttribute("Type") == "Barrel" then return true end
    if obj:FindFirstChild("Barrel", true) then return true end
    if obj.Name == "m_Zombie" and obj:FindFirstChild("Torch", true) then return true end
    return false
end

local function findTargetPart(zombie)
    if not (zombie and zombie:IsA("Model")) then return nil end
    if TargetPart == "Head" then
        local head = zombie:FindFirstChild("Head") or zombie:FindFirstChild("head")
        if head and head:IsA("BasePart") then return head end
    end
    local torso = zombie:FindFirstChild("Torso") or zombie:FindFirstChild("UpperTorso")
    if torso and torso:IsA("BasePart") then return torso end
    local hrp = zombie:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:IsA("BasePart") then return hrp end
    return nil
end

local function addToCache(model)
    if not (model and model:IsA("Model")) then return end
    local zombiesFolder = Workspace:FindFirstChild("Zombies")
    if not zombiesFolder then return end
    if not model:IsDescendantOf(zombiesFolder) then return end
    local ok, part = pcall(findTargetPart, model)
    if ok and part then HeadCache[model] = part end
end

local zombiesFolder = Workspace:FindFirstChild("Zombies")
if zombiesFolder then
    for _, z in ipairs(zombiesFolder:GetChildren()) do
        if z:IsA("Model") then addToCache(z) end
