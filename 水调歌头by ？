local flyScreenGui = nil
local function createFlyUI()
    if flyScreenGui then flyScreenGui:Destroy() end
    flyScreenGui = Instance.new("ScreenGui", PlayerGui)
    flyScreenGui.Name = "FlyUI"
    flyScreenGui.ResetOnSpawn = false

    local MainFrame = Instance.new("Frame", flyScreenGui)
