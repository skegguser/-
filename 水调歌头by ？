-- ========== 自动射击（枪械）核心 ==========
local function getNearestTargetByType(matcher)
    local camFolder = Workspace:FindFirstChild("Camera")
    if not camFolder then return nil, nil end
    local cam = Camera
    local origin = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and LocalPlayer.Character.Head.Position or cam.CFrame.Position
    if not origin then return nil, nil end
    local bestPart, bestDist, bestModel = nil, CFG.AUTO_SHOOT_MAX_RANGE + 1, nil
    for _, model in ipairs(camFolder:GetChildren()) do
        if model:IsA("Model") and model.Name == "m_Zombie" and matcher(model) then
            local head = model:FindFirstChild("Head")
            local barrel = model:FindFirstChild("Barrel")
            local part = barrel or head or model:FindFirstChild("HumanoidRootPart")
            if part and part:IsA("BasePart") then
                local d = (part.Position - origin).Magnitude
                if d <= CFG.AUTO_SHOOT_MAX_RANGE and d < bestDist then
                    if CFG.AUTO_SHOOT_WALL_CHECK then
                        local params = RaycastParams.new()
                        params.FilterType = Enum.RaycastFilterType.Blacklist
                        params.FilterDescendantsInstances = {LocalPlayer.Character, model, camFolder}
                        local res = Workspace:Raycast(origin, (part.Position - origin), params)
                        if not res then
                            bestPart, bestDist, bestModel = part, d, model
                        end
                    else
                        bestPart, bestDist, bestModel = part, d, model
                    end
                end
            end
        end
    end
    return bestPart, bestModel
end

local function autoShootLoop()
    while true do
        task.wait(0.1)
        local anyEnabled = CFG.AUTO_SHOOT_BOMBER or CFG.AUTO_SHOOT_CAVALRY or CFG.AUTO_SHOOT_RUNNER or CFG.AUTO_SHOOT_ELECTROCUTIONER or CFG.AUTO_SHOOT_IGNITER
        if not anyEnabled then continue end
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if not tool or not isGun(tool) then continue end
        if getShotsLoaded(tool) == 0 then continue end
        local matchers = {
            [CFG.AUTO_SHOOT_BOMBER] = function(m) return m:FindFirstChild("Barrel") ~= nil end,
            [CFG.AUTO_SHOOT_CAVALRY] = function(m) return m:FindFirstChild("Sword") ~= nil end,
            [CFG.AUTO_SHOOT_RUNNER] = function(m) return m:FindFirstChild("Eye") and not m:FindFirstChild("Axe") end,
            [CFG.AUTO_SHOOT_ELECTROCUTIONER] = function(m) return m:FindFirstChild("Axe") ~= nil end,
            [CFG.AUTO_SHOOT_IGNITER] = function(m) return m:FindFirstChild("Whale Oil Lantern") ~= nil end,
        }
        local bestPart, bestModel = nil, nil
        for enabled, matcher in pairs(matchers) do
            if enabled then
                local p, m = getNearestTargetByType(matcher)
                if p then bestPart, bestModel = p, m end
            end
        end
        if bestPart and bestModel then
            local remote = findRemote(tool)
            if remote then
                pcall(function() remote:FireServer("Fire", LocalPlayer.Character:FindFirstChild("Model") or LocalPlayer.Character, bestPart.Position, Workspace:GetServerTimeNow()) end)
            end
        end
    end
end
