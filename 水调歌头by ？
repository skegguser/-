    end)
    if success then flyControlModule = module; return module end
    return nil
end

-- 飞行启动/停止
local function startFly()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    local animate = char:FindFirstChild("Animate")
    if animate then flyAnimCache = animate; animate.Parent = nil end
    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    flyBodyVelocity.Parent = hrp
    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    flyBodyGyro.P = 8000
    flyBodyGyro.Parent = hrp
    flyThread = spawn(function()
        local ctrl = getControlModule()
        while FLY_ENABLED and char and char.Parent do
            if ctrl then
                local moveVec = ctrl:GetMoveVector()
                local camCF = Camera.CFrame
                local moveDir = (camCF.LookVector * -moveVec.Z) + (camCF.RightVector * moveVec.X)
                if moveVec.Magnitude > 0 then
                    flyBodyVelocity.Velocity = moveDir.Unit * FLY_SPEED
                    flyBodyGyro.CFrame = CFrame.new(Vector3.zero, moveDir)
                else
                    flyBodyVelocity.Velocity = Vector3.new(0, 0.01, 0)
                    flyBodyGyro.CFrame = CFrame.new(Vector3.zero, Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z))
                end
                hum:ChangeState(Enum.HumanoidStateType.Climbing)
            end
            RunService.RenderStepped:Wait()
        end
        if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
        if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
        if flyAnimCache then flyAnimCache.Parent = char; flyAnimCache = nil end
        if hum and hum:GetState() == Enum.HumanoidStateType.Climbing then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end)
end
local function stopFly()
    if flyThread then coroutine.close(flyThread); flyThread = nil end
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
    if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
    if flyAnimCache and LocalPlayer.Character then flyAnimCache.Parent = LocalPlayer.Character; flyAnimCache = nil end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum and hum:GetState() == Enum.HumanoidStateType.Climbing then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
end

-- 无敌（碰飞）功能
local function findPlayer(text)
    text = text:lower()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Name:lower():find(text) or plr.DisplayName:lower():find(text) then return plr end
    end
end
LocalPlayer.Chatted:Connect(function(msg)
    if not WUDI_ON then return end
    if msg:sub(1,6):lower() == ";kill " then
        local name = msg:sub(7)
        local plr = findPlayer(name)
        if plr and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            wudiTargetPlayer = plr
        end
    end
end)
spawn(function()
    while wudiMoveLoopRunning do
        wait()
        if not WUDI_ON or not wudiTargetPlayer then
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum:Move(Vector3.zero) end
            continue
        end
        local char = wudiTargetPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
            wudiTargetPlayer = nil
            continue
        end
        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local targetHRP = char:FindFirstChild("HumanoidRootPart")
        if myHRP and targetHRP then
            local offset = targetHRP.Velocity.Magnitude < 0.1 and 0 or 7
            local goal = targetHRP.CFrame * CFrame.new(0,0,-offset) * CFrame.Angles(0, math.rad(-3), 0)
            myHRP.CFrame = myHRP.CFrame:Lerp(goal, 0.4)
            myHRP.Velocity = Vector3.new(0,0,0)
            myHRP.RotVelocity = Vector3.new(0,0,0)
        end
    end
end)
spawn(function()
    while wudiPushLoopRunning do
        wait()
        if not WUDI_ON then
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum:Move(Vector3.zero) end
            continue
        end
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum:Move(Vector3.one * 1e31) end
    end
end)

-- 重写移速控制：如果 Speed增强 开启，则覆盖 LoopSpeed；否则恢复 LoopSpeed 控制
local originalWalkSpeed = nil
spawn(function()
    while true do
        wait()
        local char = LocalPlayer.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then continue end
        if originalWalkSpeed == nil then originalWalkSpeed = hum.WalkSpeed end
        if FLY_ENABLED then
            -- 飞行时移速由 BodyVelocity 控制，不干扰
            -- 保持原有移速不变
        elseif SPEED_ENHANCE_ON then
            hum.WalkSpeed = SPEED_ENHANCE_VALUE
        else
            hum.WalkSpeed = LOOP_SPEED_VAL
        end
    end
end)

