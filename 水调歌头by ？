local function scanTarget()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local closest, minDist = nil, CFG.SCAN_DIST
    local dangerZones = getDangerZones()
    local folders = {workspace:FindFirstChild("Zombies"), workspace:FindFirstChild("Camera")}
    for _, f in pairs(folders) do 
        if f then 
            for _, z in ipairs(f:GetChildren()) do
                if z:IsA("Model") then
                    local zr = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
                    local hum = z:FindFirstChildOfClass("Humanoid")
                    if zr and hum and hum.Health > 0 then
                        local isTooCloseToBarrel = false
                        if not CFG.FACE_BOMBER then 
                            for _, barrelPos in ipairs(dangerZones) do
                                if (zr.Position - barrelPos).Magnitude < 5 then isTooCloseToBarrel = true break end
                            end
                        end
                        local wallBlock = false
                        if CFG.WALL_CHECK then if isBehindWall(zr) then wallBlock = true end end
                        if not isTooCloseToBarrel and not wallBlock then
                            local d = (hrp.Position - zr.Position).Magnitude 
                            if d < minDist then closest, minDist = z, d end 
                        end
                    end
                end
            end 
        end 
    end
    currentTarget = closest
end

local function createESP(model, color, label)
    if espHighlights[model] then return end
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
    if not torso then return end
    local hl = Instance.new("Highlight", model)
    hl.FillColor, hl.OutlineColor, hl.FillTransparency, hl.OutlineTransparency, hl.DepthMode = color, Color3.new(1,1,1), 0.6, 0.2, Enum.HighlightDepthMode.AlwaysOnTop
    local bgui = Instance.new("BillboardGui", torso)
    bgui.Size, bgui.AlwaysOnTop, bgui.StudsOffset = UDim2.new(0, 100, 0, 40), true, Vector3.new(0, 3.5, 0)
    local tl = Instance.new("TextLabel", bgui)
    tl.BackgroundTransparency, tl.Size, tl.Text, tl.TextColor3, tl.TextStrokeTransparency, tl.TextSize, tl.Font = 1, UDim2.new(1, 0, 1, 0), "[ " .. label .. " ]", color, 0.5, 13, Enum.Font.GothamBold
    espHighlights[model] = {hl = hl, gui = bgui}
end

