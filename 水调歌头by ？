local GunTab = Sections.Gun:Tab({ Title = "Auto Shooting", Icon = "target" })

-- Safety globals
local BOMBER_SAFE_TEAMMATES = true   -- default don't shoot near teammates
local BOMBER_SAFE_RADIUS = 12
local AUTO_SHOOT_ENABLED = false
local AUTO_RELOAD_ENABLED = false
local MAX_RANGE = 200

-- Helper: check if bomber has teammate within radius
local function isBomberNearTeammate(bomberModel)
    if not BOMBER_SAFE_TEAMMATES then return false end
    local bomberPart = bomberModel:FindFirstChild("HumanoidRootPart") or bomberModel:FindFirstChildWhichIsA("BasePart")
    if not bomberPart then return false end
    local bomberPos = bomberPart.Position
    for _, pl in ipairs(game.Players:GetPlayers()) do
        if pl ~= game.Players.LocalPlayer and pl.Character then
            local hrp = pl.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - bomberPos).Magnitude <= BOMBER_SAFE_RADIUS then
                return true
            end
        end
    end
    return false
end

-- Gun check
local function isGun(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local anim = tool:FindFirstChild("Animations")
    return anim and (anim:FindFirstChild("Aim") or anim:FindFirstChild("Aiming"))
end

local function getShotsLoaded(tool)
    if not tool then return 0 end
    local s = tool:FindFirstChild("ShotsLoaded")
    if s and (s:IsA("IntValue") or s:IsA("NumberValue")) then return s.Value end
    local ws = workspace:FindFirstChild("Players")
    if ws and ws:FindFirstChild(game.Players.LocalPlayer.Name) then
        local tf = ws[game.Players.LocalPlayer.Name]:FindFirstChild(tool.Name)
        if tf then
            local sv = tf:FindFirstChild("ShotsLoaded")
            if sv then return sv.Value end
        end
    end
    return 0
end

local function getRemote(tool)
    if not tool then return nil end
    local r = tool:FindFirstChild("RemoteEvent")
    if r then return r end
    local ws = workspace:FindFirstChild("Players")
    if ws and ws:FindFirstChild(game.Players.LocalPlayer.Name) then
        local tf = ws[game.Players.LocalPlayer.Name]:FindFirstChild(tool.Name)
        if tf then return tf:FindFirstChild("RemoteEvent") end
    end
    return nil
end

-- Wall check (from blackgun.lua simplified)
local function isObstructed(origin, targetPos, targetModel)
    if not origin or not targetPos then return false end
    local dir = targetPos - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    local ignore = {}
    for _, pl in ipairs(game.Players:GetPlayers()) do if pl.Character then table.insert(ignore, pl.Character) end end
    if targetModel then table.insert(ignore, targetModel) end
    params.FilterDescendantsInstances = ignore
    local result = workspace:Raycast(origin, dir, params)
    return result and not result.Instance:IsDescendantOf(targetModel)
end

-- Find nearest bomber
local function getNearestBomber()
    local camFolder = workspace:FindFirstChild("Camera")
    if not camFolder then return nil, nil end
    local origin = nil
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Head") then origin = char.Head.Position
    else origin = workspace.CurrentCamera.CFrame.Position end
    local bestPart, bestModel, bestDist = nil, nil, MAX_RANGE+1
    for _, model in ipairs(camFolder:GetChildren()) do
        if model:IsA("Model") and model.Name == "m_Zombie" and model:FindFirstChild("Barrel") then
            local barrel = model:FindFirstChild("Barrel")
            if barrel and barrel:IsA("BasePart") then
                local dist = (barrel.Position - origin).Magnitude
                if dist <= MAX_RANGE and dist < bestDist then
                    if not isObstructed(origin, barrel.Position, model) and not isBomberNearTeammate(model) then
                        bestPart, bestModel, bestDist = barrel, model, dist
                    end
                end
            end
        end
    end
    return bestPart, bestModel
end

-- Shoot logic (no simulated clicks, only remote firing)
local function aimAndShoot(targetPart, targetModel, tool)
    if not targetPart or not targetModel or not tool then return end
    local remote = getRemote(tool)
    if not remote then return end
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local myHead = char:FindFirstChild("Head")
    local origin = myHead and myHead.Position or workspace.CurrentCamera.CFrame.Position
    if isObstructed(origin, targetPart.Position, targetModel) then return end
    if isBomberNearTeammate(targetModel) then return end  -- safety double-check
    local modelRef = char:FindFirstChild("Model") or char
    pcall(function()
        remote:FireServer("Fire", modelRef, targetPart.Position, workspace:GetServerTimeNow())
    end)
end

-- Auto shoot loop
task.spawn(function()
    while true do
        task.wait(0.15)
        if not AUTO_SHOOT_ENABLED then continue end
        local tool = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if not tool or not isGun(tool) then continue end
        if getShotsLoaded(tool) < 1 then
            if AUTO_RELOAD_ENABLED then
                local remote = getRemote(tool)
                if remote then pcall(remote.FireServer, remote, "Reload") end
            end
            continue
        end
        local targetPart, targetModel = getNearestBomber()
        if targetPart and targetModel then
            aimAndShoot(targetPart, targetModel, tool)
        end
    end
end)

