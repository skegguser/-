local function getDangerZones()
    local zones = {}
    for _, model in ipairs(workspace:GetChildren()) do
        if model:IsA("Model") and (model.Name:find("Bomber") or model:FindFirstChild("Barrel")) then
            local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Barrel")
            if root then table.insert(zones, root.Position) end
        end
    end
    local camFolder = workspace:FindFirstChild("Camera")
    if camFolder then
        for _, m in ipairs(camFolder:GetChildren()) do
            if m.Name:find("Bomber") or m:FindFirstChild("Barrel") then
                local r = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Barrel")
                if r then table.insert(zones, r.Position) end
            end
        end
    end
    return zones
end

local function isBehindWall(targetPart)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not targetPart then return true end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, workspace:FindFirstChild("Zombies"), workspace:FindFirstChild("Camera"), BeamFolder}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local origin = hrp.Position
    local direction = targetPart.Position - origin
    local raycastResult = workspace:Raycast(origin, direction, raycastParams)
    return raycastResult ~= nil
end

local function scanTarget()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local closest, minDist = nil, CFG.SCAN_DIST
    local dangerZones = getDangerZones()
    local folders = {workspace:FindFirstChild("Zombies"), workspace:FindFirstChild("Camera")}
    for _, f in pairs(folders) do 
        if f then 
            for _, z in ipairs(f:GetChildren()) do
                if z:IsA("Model") then
                    local zr = z:FindFirstChild("HumanoidRootPart") or z:FindFirstChild("Torso")
                    local hum = z:FindFirstChildOfClass("Humanoid")
                    if zr and hum and hum.Health > 0 then
                        local isTooCloseToBarrel = false
                        if not CFG.FACE_BOMBER then 
                            for _, barrelPos in ipairs(dangerZones) do
                                if (zr.Position - barrelPos).Magnitude < 5 then isTooCloseToBarrel = true break end
                            end
                        end
                        local wallBlock = false
                        if CFG.WALL_CHECK then if isBehindWall(zr) then wallBlock = true end end
                        if not isTooCloseToBarrel and not wallBlock then
                            local d = (hrp.Position - zr.Position).Magnitude 
                            if d < minDist then closest, minDist = z, d end 
                        end
                    end
                end
            end 
        end 
    end
    currentTarget = closest
end

local function createESP(model, color, label)
    if espHighlights[model] then return end
    local torso = model:FindFirstChild("Torso") or model:FindFirstChild("HumanoidRootPart")
    if not torso then return end
    local hl = Instance.new("Highlight", model)
    hl.FillColor, hl.OutlineColor, hl.FillTransparency, hl.OutlineTransparency, hl.DepthMode = color, Color3.new(1,1,1), 0.6, 0.2, Enum.HighlightDepthMode.AlwaysOnTop
