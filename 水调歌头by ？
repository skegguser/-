        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local tPart = currentTarget:FindFirstChild("HumanoidRootPart") or currentTarget:FindFirstChild("Head")
        if hrp and tPart then
            local dist = (hrp.Position - tPart.Position).Magnitude
            laser.Size = Vector3.new(0.05, 0.05, dist)
            laser.CFrame = CFrame.new(hrp.Position:Lerp(tPart.Position, 0.5), tPart.Position)
            laser.Transparency = 0.4
            return
        end
    end
    laser.Transparency = 1 
end)

