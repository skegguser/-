local function updateZombieESP()
    local camFolder = Workspace:FindFirstChild("Camera")
    if not camFolder then return end
    local enabledTypes = {}
    if CFG.ESP_BOMBER then enabledTypes.Bomber = true end
    if CFG.ESP_CUIRASSIER then enabledTypes.Cuirassier = true end
    if CFG.ESP_RUNNER then enabledTypes.Runner = true end
    if CFG.ESP_ZAPPER then enabledTypes.Zapper = true end
    if CFG.ESP_IGNITER then enabledTypes.Igniter = true end
    local seen = {}
    for _, obj in ipairs(camFolder:GetChildren()) do
        if obj:IsA("Model") and obj.Name == "m_Zombie" then
            local espType = nil
            if enabledTypes.Bomber and obj:FindFirstChild("Barrel") then espType = "Bomber"
            elseif enabledTypes.Cuirassier and obj:FindFirstChild("Sword") then espType = "Cuirassier"
            elseif enabledTypes.Runner and obj:FindFirstChild("Eye") and not obj:FindFirstChild("Axe") then espType = "Runner"
            elseif enabledTypes.Zapper and obj:FindFirstChild("Axe") then espType = "Zapper"
            elseif enabledTypes.Igniter and obj:FindFirstChild("Whale Oil Lantern") then espType = "Igniter" end
            if espType then
                seen[obj] = true
                if not espHighlights[obj] then createZombieESP(obj, espType) end
            end
        end
    end
    for model, data in pairs(espHighlights) do
        if not seen[model] then
            if data.hl then data.hl:Destroy() end
            if data.bb then data.bb:Destroy() end
            espHighlights[model] = nil
        end
    end
end
