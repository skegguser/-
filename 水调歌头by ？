        local aimPos = silentAimCurrentTarget.Position
        local dir = (aimPos - origin)
        args[2] = dir.Unit * (dir.Magnitude + 10)
        return oldNamecall(self, unpack(args))
    end
    return oldNamecall(self, ...)
end)

