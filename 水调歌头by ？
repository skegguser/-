local function applyThemeColors(frame, isTitle)
    if CurrentTheme == "Dark" then frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) if not isTitle then frame.BackgroundTransparency = 0.5 end
    elseif CurrentTheme == "Glass" then frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255) if not isTitle then frame.BackgroundTransparency = 0.8 end
    elseif CurrentTheme == "Neon" then frame.BackgroundColor3 = Color3.fromRGB(20, 0, 40) if not isTitle then frame.BackgroundTransparency = 0.3 end
    elseif CurrentTheme == "Midnight" then frame.BackgroundColor3 = Color3.fromRGB(5, 5, 15) if not isTitle then frame.BackgroundTransparency = 0.2 end
    elseif CurrentTheme == "DeepSea" then frame.BackgroundColor3 = Color3.fromRGB(0, 15, 25) if not isTitle then frame.BackgroundTransparency = 0.25 end end
end

local BASE_WIDTH = 90
local BASE_FONT_SIZE = 8

local function updateFontSizes()
    local scale = math.max(0.6, math.min(2, UI_WIDTH / BASE_WIDTH))
    local newSize = math.floor(BASE_FONT_SIZE * scale)
    for _, btn in ipairs(AllButtons) do if btn:IsA("TextButton") then btn.TextSize = newSize end end
    for _, title in ipairs(AllTitles) do if title:IsA("TextButton") then title.TextSize = math.floor(newSize * 1.2) end end
    updateStatusPanel()
end

local function applyDreamyGradient(label)
    local textGradient = label:FindFirstChild("DreamyGradient") or Instance.new("UIGradient")
    textGradient.Name, textGradient.Color, textGradient.Parent = "DreamyGradient", ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 100, 255)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 200, 255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 255, 200))}), label
    local accent = label:FindFirstChild("AccentFrame")
    if label:IsA("TextLabel") and not accent then
        accent = Instance.new("Frame")
        accent.Name, accent.Size, accent.Position, accent.BorderSizePixel, accent.Parent = "AccentFrame", UDim2.new(0, 2, 1, 0), UDim2.new(1, 0, 0, 0), 0, label
    end
    local accentGradient
    if accent then accentGradient = accent:FindFirstChildOfClass("UIGradient") or Instance.new("UIGradient") accentGradient.Rotation, accentGradient.Parent = 90, accent end
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not label or not label.Parent then connection:Disconnect() return end
        local isStatus = label.Parent == StatusPanel
        local active = isStatus or UseTextGradient
        textGradient.Enabled = active
        if accent then accent.Visible = active end
        if active then
            local t = tick()
            local seq = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromHSV((t * 0.2) % 1, 0.5, 1)), ColorSequenceKeypoint.new(1, Color3.fromHSV((t * 0.2 + 0.3) % 1, 0.5, 1))})
            textGradient.Color = seq
            if accentGradient then accentGradient.Color = seq end
        else label.TextColor3 = getThemeTextColor() end
    end)
end

local function updateStatusPanel()
    for _, child in ipairs(StatusPanel:GetChildren()) do if child:IsA("TextLabel") then child:Destroy() end end
    if not ShowStatus then return end
    local scale = math.max(0.6, math.min(2, UI_WIDTH / BASE_WIDTH))
    local titleSize = math.floor(12 * scale)
    local textSize = math.floor(10 * scale)
    local header = Instance.new("TextLabel")
    header.Size, header.AutomaticSize, header.BackgroundTransparency, header.BackgroundColor3, header.BorderSizePixel, header.Text, header.Font, header.TextSize, header.TextColor3, header.TextXAlignment, header.LayoutOrder, header.Parent = UDim2.new(0, 0, 0, 16), Enum.AutomaticSize.X, 0.4, Color3.new(0,0,0), 0, "SDGT ELIT  ", Enum.Font.GothamBold, titleSize, Color3.new(1,1,1), Enum.TextXAlignment.Right, -1, StatusPanel
    applyDreamyGradient(header)
    local activeNames = {}
    for name, state in pairs(FeatureStates) do if state then table.insert(activeNames, name) end end
    table.sort(activeNames, function(a, b) return #(a .. "  ") > #(b .. "  ") end)
    for i, name in ipairs(activeNames) do
        local label = Instance.new("TextLabel")
        label.Size, label.AutomaticSize, label.BackgroundTransparency, label.BackgroundColor3, label.BorderSizePixel, label.Text, label.Font, label.TextSize, label.TextColor3, label.TextXAlignment, label.LayoutOrder, label.Parent, label.Position, label.TextTransparency = UDim2.new(0, 0, 0, 14), Enum.AutomaticSize.X, 0.4, Color3.new(0,0,0), 0, name .. "  ", Enum.Font.GothamBold, textSize, Color3.new(1, 1, 1), Enum.TextXAlignment.Right, i, StatusPanel, UDim2.new(0, 20, 0, 14), 1
        applyDreamyGradient(label)
        TweenService:Create(label, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 0, 14), TextTransparency = 0}):Play()
    end
end

local function updateUISizes()
    MainFrame.Size = UDim2.fromOffset(UI_WIDTH, (MainFrame.Size.Y.Offset > BAR_HEIGHT + 5) and UI_HEIGHT or BAR_HEIGHT)
    for _, sub in pairs(SubUIFrames) do
        local isExpanded = sub.Size.Y.Offset > BAR_HEIGHT + 5
        sub.Size = UDim2.fromOffset(UI_WIDTH, isExpanded and UI_HEIGHT or BAR_HEIGHT)
        local scroll = sub:FindFirstChildOfClass("ScrollingFrame")
        if scroll then scroll.Size = UDim2.new(1, 0, 1, -BAR_HEIGHT) end
    end
    local mainScroll = MainFrame:FindFirstChildOfClass("ScrollingFrame")
    if mainScroll then mainScroll.Size = UDim2.new(1, 0, 1, -BAR_HEIGHT) end
    updateFontSizes()
end

local function updateAllThemes()
    local txtCol = getThemeTextColor()
    applyThemeColors(MainFrame, false)
    applyThemeColors(MainTitle, true)
    MainTitle.TextColor3 = txtCol
    for _, btn in ipairs(AllButtons) do btn.TextColor3 = txtCol end
    for _, f in pairs(SubUIFrames) do
        applyThemeColors(f, false)
        local t = f:FindFirstChildOfClass("TextButton")
        if t then applyThemeColors(t, true) t.TextColor3 = txtCol end
    end
    updateStatusPanel()
end

local function setupDraggableAndToggle(frame, titleBar, contentFrame, isMain)
    local dragging, dragStart, startPos, hasMoved, clickTime, inputConnection = false, nil, nil, false, nil, nil
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging, hasMoved, dragStart, startPos, clickTime = true, false, input.Position, frame.Position, tick()
            if inputConnection then inputConnection:Disconnect() end
            inputConnection = UserInputService.InputChanged:Connect(function(moveInput)
                if dragging and (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) then
                    local delta = moveInput.Position - dragStart
                    if delta.Magnitude > 5 and (isMain or not LockSubUIs) then hasMoved = true frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y) end
                end
            end)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                if inputConnection then inputConnection:Disconnect() inputConnection = nil end
                if not hasMoved and clickTime and (tick() - clickTime) < 0.5 then
                    local expanded = frame.Size.Y.Offset > BAR_HEIGHT + 5
                    TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Size = UDim2.fromOffset(UI_WIDTH, expanded and BAR_HEIGHT or UI_HEIGHT)}):Play()
                    contentFrame.Visible = not expanded
                end
            end
        end
    end)
end

local function createBaseFrame(name)
    local frame = Instance.new("Frame")
    frame.Name, frame.Size, frame.BorderSizePixel, frame.Visible, frame.ClipsDescendants = name, UDim2.fromOffset(UI_WIDTH, UI_HEIGHT), 0, false, true
    applyThemeColors(frame, false)
    local bgGradient = Instance.new("UIGradient")
    bgGradient.Color, bgGradient.Rotation, bgGradient.Transparency, bgGradient.Parent = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 20)), ColorSequenceKeypoint.new(1, Color3.fromRGB(40, 0, 60))}), 45, NumberSequence.new(0, 0.2), frame
    local stroke = Instance.new("UIStroke")
    stroke.Thickness, stroke.ApplyStrokeMode, stroke.Parent = 1, Enum.ApplyStrokeMode.Border, frame
    table.insert(UIStrokes, stroke)
    local glow = Instance.new("UIStroke")
    glow.Thickness, glow.ApplyStrokeMode, glow.Transparency, glow.Parent = 3, Enum.ApplyStrokeMode.Border, 0.8, frame
    table.insert(UIStrokes, glow)
    return frame
end

local function createTitleBar(parent, text)
    local bar = Instance.new("TextButton")
    local scale = math.max(0.6, math.min(2, UI_WIDTH / BASE_WIDTH))
    local fontSize = math.floor(BASE_FONT_SIZE * 1.2 * scale)
    bar.Size, bar.BorderSizePixel, bar.Text, bar.Font, bar.TextSize, bar.TextColor3, bar.Parent = UDim2.new(1, 0, 0, BAR_HEIGHT), 0, text, Enum.Font.GothamBold, fontSize, getThemeTextColor(), parent
    applyThemeColors(bar, true)
    table.insert(AllTitles, bar)
    return bar
end

local function createFeatureButton(parent, internalName, isCategory, clickCallback, isAction)
    local btn = Instance.new("TextButton")
    local scale = math.max(0.6, math.min(2, UI_WIDTH / BASE_WIDTH))
    local fontSize = math.floor(BASE_FONT_SIZE * scale)
    btn.Size, btn.BackgroundTransparency, btn.Text, btn.Font, btn.TextSize, btn.TextColor3, btn.BorderSizePixel, btn.Parent = UDim2.new(1, 0, 0, BAR_HEIGHT), 1, internalName, Enum.Font.Gotham, fontSize, getThemeTextColor(), 0, parent
    table.insert(AllButtons, btn)
    applyDreamyGradient(btn)
    btn.MouseButton1Click:Connect(function()
        if isAction then
            if clickCallback then clickCallback() end
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.5, BackgroundColor3 = TARGET_BLACK}):Play()
            delay(0.1, function() TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play() end)
        elseif isCategory then
            CategoryStates[internalName] = not CategoryStates[internalName]
            local s = CategoryStates[internalName]
            TweenService:Create(btn, TweenInfo.new(0.3, Enum.EasingStyle.Back), {BackgroundTransparency = s and 0.6 or 1, BackgroundColor3 = s and TARGET_BLACK or Color3.new(0,0,0)}):Play()
            if clickCallback then clickCallback() end
        else
            FeatureStates[internalName] = not FeatureStates[internalName]
            local s = FeatureStates[internalName]
            TweenService:Create(btn, TweenInfo.new(0.3, Enum.EasingStyle.Back), {BackgroundTransparency = s and 0.6 or 1, BackgroundColor3 = s and TARGET_BLACK or Color3.new(0,0,0)}):Play()
            updateStatusPanel()
            if clickCallback then clickCallback() end 
        end
    end)
    return btn
end

