setfpscap(10000)
local config = {
    freeze_delay = 0.5,
    smooth = false
}
local players = game:GetService("Players")
local runService = game:GetService("RunService")
local localPlayer = players.LocalPlayer

local setPhysicsSenderRate = (function()
    local fflag = "S2PhysicsSenderRate"

    return (function(rate)
        setfflag(fflag, tostring(rate))
    end)
end)()
local getHumanoidRootPart = (function()
    local findFirstChild = game.FindFirstChild

    return (function()
        local character = localPlayer.Character
        return character and findFirstChild(character, "HumanoidRootPart")
    end)
end)()
local setSleepingState = (function()
    local property = "NetworkIsSleeping"

    return (function(state)
        local rootPart = getHumanoidRootPart()
        if rootPart then
            sethiddenproperty(rootPart, property, state)
        end
    end)
end)()

if connection then
    connection:Disconnect()
    connection = nil
end
if not getHumanoidRootPart() then
    return
end
local stepCounter = 1
local toggleRate = 2


getgenv().connection = runService.Heartbeat:Connect(function()
    stepCounter = (stepCounter % toggleRate) + 1
    local isSleeping = stepCounter % toggleRate ~= 0
    setSleepingState(isSleeping)
end)
setPhysicsSenderRate(32767)

for _ = 1, 3 do
    localPlayer.Character.HumanoidRootPart.AssemblyLinearVelocity += Vector3.new(0, 1, 0) -- im not sure if we actually need it
    runService.Heartbeat:Wait()
end

local startTime = tick()
while tick() - startTime < config.freeze_delay do end -- freeze simulation
task.wait(2)
toggleRate = config.smooth and 4 or toggleRate
setPhysicsSenderRate(-1)
